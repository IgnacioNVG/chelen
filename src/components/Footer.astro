---
const today = new Date();
---

<footer>
    <div class="footer-content">
        <div class="brand">
            <span class="sifonn">Chelén</span>
            <p>Socialismo y Weas</p>
        </div>
        
        <div class="legal">
            <div class="footer-nav">
                <a href="/about">Nosotros</a> • 
                <a href="/organizacion">Organización</a>
            </div>
            
            <div class="contact-line">
                Contacto : <a href="mailto:contacto@revistachelen.cl">contacto@revistachelen.cl</a>
            </div>

            <div class="copyright">
                &copy; {today.getFullYear()} — Santiago de Chile. <br/>
                Registro en construcción.
            </div>
        </div>

        <div class="social-links">
            <a href="https://instagram.com/revista.chelen" target="_blank" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
            <a href="mailto:contacto@revistachelen.cl" aria-label="Email">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </a>
        </div>
    </div>
</footer>

<style>
    footer {
        /* Padding mejorado: más espacio superior e inferior para un look editorial */
        padding: 5rem 2rem 5rem 2rem;
        background: #111;
        color: #fff;
        border-top: 8px solid #ff0000;
        margin-top: 6rem;
    }

    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        align-items: start;
        gap: 3rem;
    }

    .brand .sifonn {
        font-family: 'Sifonn', sans-serif;
        font-size: 2.2rem;
        text-transform: uppercase;
        display: block;
        line-height: 1;
        margin-bottom: 0.8rem;
    }

    .brand p {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        opacity: 0.8;
        margin: 0;
    }

    .legal {
        font-family: monospace;
        font-size: 0.85rem;
        text-align: center;
        line-height: 1.6;
    }

    .footer-nav {
        margin-bottom: 1.5rem;
    }

    .footer-nav a {
        color: #fff;
        text-decoration: none;
        font-weight: bold;
        padding: 0 0.5rem;
        transition: color 0.2s ease;
    }

    /* Estilo para la línea de contacto solicitada */
    .contact-line {
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .contact-line a {
        color: #fff;
        text-decoration: none;
        border-bottom: 1px solid #fff;
        padding-bottom: 2px;
        transition: all 0.2s ease;
    }

    .contact-line a:hover, .footer-nav a:hover {
        color: #ff0000;
        border-color: #ff0000;
    }

    .copyright {
        opacity: 0.5;
        font-size: 0.75rem;
    }

    .social-links {
        display: flex;
        justify-content: flex-end;
        gap: 2rem;
    }

    .social-links a {
        color: #fff;
        transition: all 0.2s ease;
    }

    .social-links a:hover {
        color: #ff0000;
        transform: scale(1.1);
    }

    /* Adaptabilidad para móviles */
    @media (max-width: 768px) {
        footer {
            padding: 4rem 1.5rem;
        }
        .footer-content {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 2.5rem;
        }
        .social-links {
            justify-content: center;
        }
    }
</style>