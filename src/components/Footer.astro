---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="brand">
			<span class="sifonn">Chelén</span>
			<p>Socialismo y Weas</p>
		</div>
		
		<div class="legal">
			<div class="footer-nav">
				<a href="/about">Nosotros</a> • 
				<a href="/organizacion">Organización</a>
			</div>
			&copy; {today.getFullYear()} — Santiago de Chile. <br/>
			Registro en construcción.
		</div>

		<div class="social-links">
			<a href="https://instagram.com/revista.chelen" target="_blank" aria-label="Instagram">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
			</a>
			<a href="mailto:contacto@chelen.cl" aria-label="Email">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
			</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 4rem 2rem 6rem 2rem;
		background: #111;
		color: #fff;
		border-top: 8px solid #ff0000;
		margin-top: 4rem;
	}

	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		align-items: start;
		gap: 2rem;
	}

	.brand .sifonn {
		font-family: 'Sifonn', sans-serif;
		font-size: 2rem;
		text-transform: uppercase;
		display: block;
		line-height: 1;
		margin-bottom: 0.5rem;
	}

	.brand p {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.7;
	}

	.legal {
		font-family: monospace;
		font-size: 0.8rem;
		text-align: center;
		opacity: 0.6;
	}

	.footer-nav {
		margin-bottom: 1rem;
		opacity: 1;
	}

	.footer-nav a {
		color: #fff;
		text-decoration: none;
		font-weight: bold;
		margin: 0 0.5rem;
	}

	.footer-nav a:hover {
		color: #ff0000;
	}

	.social-links {
		display: flex;
		justify-content: flex-end;
		gap: 1.5rem;
	}

	.social-links a {
		color: #fff;
		transition: color 0.2s ease, transform 0.2s ease;
	}

	.social-links a:hover {
		color: #ff0000;
		transform: translateY(-3px);
	}

	@media (max-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.social-links { justify-content: center; }
	}
</style>