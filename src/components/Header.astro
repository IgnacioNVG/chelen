---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<div class="logo">
			<a href="/">
				<img src="/favicon.svg" alt="" width="24" height="24" />
				<span class="sifonn">{SITE_TITLE}</span>
			</a>
		</div>

		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/grafica">Grafica</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">Nosotros</HeaderLink>
		</div>

		<div class="contact-links">
			<a href="https://instagram.com/revista.chelen" target="_blank">IG</a>
			<a href="mailto:contacto@chelen.cl">Mail</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2rem;
		background: #E5E5E5;
		border-bottom: 2px solid #ff0000;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between; /* Esto separa los 3 bloques */
		min-height: 70px;
		max-width: 1400px;
		margin: 0 auto;
	}

	/* BLOQUE LOGO */
	.logo a {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: #000;
	}

	.sifonn {
		font-family: 'Sifonn', sans-serif;
		font-size: 1.8rem;
		text-transform: uppercase;
		line-height: 1;
	}

	/* BLOQUE NAVEGACIÓN (Centro) */
	.internal-links {
		display: flex;
		gap: 0.5rem;
	}

	header :global(a) {
		padding: 0.5rem 1rem;
		color: #000;
		text-decoration: none;
		text-transform: uppercase;
		font-family: monospace;
		font-weight: bold;
		font-size: 0.9rem;
		border-bottom: 3px solid transparent;
	}

	header :global(a.active),
	header :global(a:hover) {
		border-bottom-color: #ff0000;
	}

	/* BLOQUE DERECHA */
	.contact-links {
		display: flex;
		gap: 1rem;
	}

	.contact-links a {
		font-size: 0.8rem;
		opacity: 0.7;
	}

	/* --- RESPONSIVE MÓVIL --- */
	@media (max-width: 720px) {
		header {
			padding: 0;
		}

		nav {
			flex-direction: column;
			min-height: auto;
		}

		.logo {
			padding: 1rem 0;
			width: 100%;
			border-bottom: 1px solid rgba(0,0,0,0.1);
			display: flex;
			justify-content: center;
		}

		.internal-links {
			display: grid;
			grid-template-columns: 1fr 1fr;
			width: 100%;
			gap: 0;
		}

		header :global(a) {
			text-align: center;
			padding: 1.2rem 0;
		}

		.contact-links {
			display: none; /* Ocultamos redes en móvil para priorizar secciones */
		}
	}
</style>