---
import { getCollection } from "astro:content";
import SectionLayout from "../layouts/SectionLayout.astro";
import ItemCard from "../components/ItemCard.astro";
import { SITE_TITLE } from "../consts";
import { resolveAuthorRef } from "../lib/authorSlug";

const articulos = await getCollection("articulos");
const poemas = await getCollection("poemas");
const cartas = await getCollection("cartas");
const entrevistas = await getCollection("entrevistas");
const columnas = await getCollection("columnas");

const allPosts = [
    ...articulos,
    ...poemas,
    ...cartas,
    ...entrevistas,
    ...columnas,
]
    .sort((a, b) => {
        const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
        const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
        return dateB - dateA;
    })
    .map((post) => {
        let imageSrc = null;
        if (post.data.heroImage) {
            imageSrc =
                typeof post.data.heroImage === "string"
                    ? post.data.heroImage
                    : post.data.heroImage.src;
        }

        // Regla general de diseño (Aspect Ratio)
        const isPortrait =
            post.collection === "cartas" ||
            post.collection === "poemas" ||
            post.collection === "grafica" ||
            post.collection === "antologias";
        const linkPrefix = [
            "articulos",
            "cartas",
            "columnas",
            "entrevistas",
        ].includes(post.collection)
            ? "/publicaciones"
            : "";

        return {
            id: post.id,
            collection: post.collection,
            title: post.data.title,
            author: resolveAuthorRef(post.data.author) || "Redacción Chelén",
            description: post.data.description || "",
            category: post.data.category || post.collection,
            image: imageSrc,
            url: `${linkPrefix}/${post.collection}/${post.id}/`,
            formatClass: isPortrait ? "format-portrait" : "format-landscape",
        };
    });

const sugerenciasPredeterminadas = allPosts.slice(0, 6);
---

<SectionLayout
    title={`Buscar - ${SITE_TITLE}`}
    description="Buscador de publicaciones"
    pageTitle="Buscador"
>
    <style>
        :global(body) {
            overflow-x: hidden;
        }

        .search-container {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding-inline: clamp(1.5rem, 5vw, 4rem);
            /* Vital para que el padding no se rompa */
            box-sizing: border-box;
            padding-top: 2rem;
            padding-bottom: 6rem;
        }

        .search-hero {
            text-align: center;
            margin-bottom: 3rem;
        }

        .search-hero h1 {
            font-size: clamp(2rem, 4vw, 3.5rem);
            margin-bottom: 1rem;
            line-height: 1.2;
        }

        .search-hero p {
            color: #666;
            font-size: 1.125rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .search-controls {
            max-width: 800px;
            margin: 0 auto 4rem auto;
        }

        .search-input {
            width: 100%;
            padding: 1rem 1.5rem;
            font-size: 1.1rem;
            border: 2px solid #eaeaea;
            border-radius: 12px;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
        }

        .search-input:focus {
            outline: none;
            border-color: #111;
        }

        /* * FIX DEL GRID Y PADDING
         * Usar minmax(0, 1fr) evita que un elemento hijo muy grande
         * expanda la columna más allá de su contenedor, arreglando el margen derecho.
         */
        .publications-grid {
            display: grid;
            grid-template-columns: repeat(1, minmax(0, 1fr));
            gap: 2rem;
            list-style: none;
            padding: 0;
            margin: 0;
            width: 100%;
            box-sizing: border-box;
        }

        @media (min-width: 768px) {
            .publications-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (min-width: 1024px) {
            .publications-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        /* * CONTROL DE IMÁGENES Y ASPECT RATIO (A prueba de balas)
         * Ataca directamente a cualquier <img> dentro de nuestras tarjetas
         * para obligarla a respetar las proporciones de forma responsiva.
         */
        :global(.search-item figure),
        :global(.search-item .item-media) {
            margin: 0;
            overflow: hidden;
            border-radius: 8px; /* Opcional: redondear esquinas de la imagen */
            width: 100%;
        }

        :global(.search-item img) {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Regla de publicaciones generales (2:1) */
        :global(li.format-landscape img),
        :global(li.format-landscape figure) {
            aspect-ratio: 2 / 1;
        }

        /* Regla de Cartas, Poemas, etc (4:5) */
        :global(li.format-portrait img),
        :global(li.format-portrait figure) {
            aspect-ratio: 4 / 5;
        }

        /* Estados y Utilidades */
        .hidden {
            display: none !important;
        }

        .empty-state {
            grid-column: 1 / -1;
            font-family: monospace;
            font-size: 1.1rem;
            text-align: center;
            color: #666;
            padding: 4rem 2rem;
            border: 2px dashed #111;
            border-radius: 8px;
            text-transform: uppercase;
            background: #f5f5f5;
        }

        .results-header {
            margin-bottom: 2rem;
            font-size: 1.5rem;
            border-bottom: 1px solid #eaeaea;
            padding-bottom: 0.5rem;
        }
    </style>

    <div class="search-container">
        <header class="search-hero">
            <h1>Explora el Archivo</h1>
            <p>
                Encuentra artículos, columnas, poemas, cartas y entrevistas
                publicadas en nuestra revista.
            </p>
        </header>

        <div class="search-controls">
            <input
                type="text"
                id="input-buscador"
                class="search-input"
                placeholder="Escribe para buscar (ej. título, autor o categoría)..."
                autocomplete="off"
            />

            <div
                id="busquedas-recientes"
                class="recent-searches-container"
                style="display: none; margin-top: 1rem;"
            >
                <span class="section-label text-sm text-gray-500"
                    >Búsquedas recientes:</span
                >
                <div
                    id="tags-recientes"
                    class="recent-tags flex gap-2 mt-2 flex-wrap"
                >
                </div>
            </div>
        </div>

        <h3 id="titulo-resultados" class="results-header">
            Sugerencias para ti
        </h3>

        <ul id="contenedor-resultados" class="publications-grid">
            <li id="mensaje-vacio" class="empty-state hidden">
                No hay resultados para tu búsqueda.
            </li>

            {
                allPosts.map((post, index) => (
                    <li
                        class={`search-item ${post.formatClass} ${index >= 6 ? "hidden not-suggestion" : "is-suggestion"}`}
                        data-title={post.title.toLowerCase()}
                        data-author={post.author.toLowerCase()}
                        data-category={post.category.toLowerCase()}
                        data-desc={post.description.toLowerCase()}
                    >
                        <ItemCard
                            href={post.url}
                            title={post.title}
                            category={post.category}
                            author={post.author}
                            image={post.image}
                            heroImage={post.image}
                            formatClass={post.formatClass}
                        />
                    </li>
                ))
            }
        </ul>
    </div>

    <script>
        const input = document.getElementById("input-buscador");
        const items = document.querySelectorAll(".search-item");
        const mensajeVacio = document.getElementById("mensaje-vacio");
        const tituloResultados = document.getElementById("titulo-resultados");

        const recientesContenedor = document.getElementById(
            "busquedas-recientes",
        );
        const tagsContenedor = document.getElementById("tags-recientes");

        let historicoBusquedas = JSON.parse(
            localStorage.getItem("chelen_busquedas_recientes") || "[]",
        );

        function actualizarUIHistorial() {
            if (historicoBusquedas.length === 0) {
                recientesContenedor.style.display = "none";
                return;
            }
            recientesContenedor.style.display = "block";
            tagsContenedor.innerHTML = historicoBusquedas
                .map(
                    (termino) =>
                        `<button class="tag-btn badge" data-term="${termino}">${termino}</button>`,
                )
                .join("");
        }

        function registrarBusqueda(termino) {
            if (!termino) return;
            historicoBusquedas = historicoBusquedas.filter(
                (t) => t !== termino,
            );
            historicoBusquedas.unshift(termino);
            if (historicoBusquedas.length > 5) historicoBusquedas.pop();
            localStorage.setItem(
                "chelen_busquedas_recientes",
                JSON.stringify(historicoBusquedas),
            );
        }

        input.addEventListener("input", (e) => {
            const query = (e.target as HTMLInputElement).value
                .toLowerCase()
                .trim();
            let matches = 0;

            if (!query) {
                tituloResultados.textContent = "Sugerencias para ti";
                mensajeVacio.classList.add("hidden");
                actualizarUIHistorial();

                items.forEach((item) => {
                    if (item.classList.contains("is-suggestion")) {
                        item.classList.remove("hidden");
                    } else {
                        item.classList.add("hidden");
                    }
                });
                return;
            }

            tituloResultados.textContent = "Resultados de búsqueda";
            recientesContenedor.style.display = "none";

            items.forEach((item) => {
                const dataset = (item as HTMLElement).dataset;
                const match =
                    dataset.title?.includes(query) ||
                    dataset.author?.includes(query) ||
                    dataset.category?.includes(query) ||
                    dataset.desc?.includes(query);

                if (match) {
                    item.classList.remove("hidden");
                    matches++;
                } else {
                    item.classList.add("hidden");
                }
            });

            if (matches === 0) {
                mensajeVacio.classList.remove("hidden");
            } else {
                mensajeVacio.classList.add("hidden");
            }
        });

        document.addEventListener("click", (e) => {
            const btnTag = (e.target as HTMLElement).closest(".tag-btn");
            if (btnTag) {
                input.value = (btnTag as HTMLElement).dataset.term || "";
                input.dispatchEvent(new Event("input"));
            }

            const cardLink = (e.target as HTMLElement).closest(
                ".item-link, .item-card a",
            );
            if (cardLink) {
                const busquedaActual = input.value.trim().toLowerCase();
                if (busquedaActual) registrarBusqueda(busquedaActual);
            }
        });

        actualizarUIHistorial();
    </script>
</SectionLayout>
