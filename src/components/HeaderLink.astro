---
import type { HTMLAttributes } from 'astro:types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

const { pathname } = Astro.url;

// Lógica mejorada: es activo si la ruta coincide exactamente 
// o si es una sub-ruta (ej: estar en un post del blog activa el link "Blog")
const isActive = href === pathname || href === pathname.replace(/\/$/, '');
const isSubRoute = pathname.startsWith(href + '/') && href !== '/';
---

<a href={href} class:list={[className, { active: isActive || isSubRoute }]} {...props}>
	<slot />
</a>

<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
    /* Ya no necesitamos el border-bottom aquí, 
       porque ahora lo maneja el nav-indicator del Header. 
       Solo mantenemos el estilo del texto.
    */
	a.active {
		font-weight: bolder;
		color: #000;
	}
</style>