---
import type { HTMLAttributes } from 'astro:types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

const { pathname } = Astro.url;

// Normalizamos las rutas para comparar sin preocuparnos por la barra final "/"
const normalizedPathname = pathname.replace(/\/$/, "");
const normalizedHref = typeof href === 'string' ? href.replace(/\/$/, "") : href;

// Es activo si:
// 1. La ruta es idéntica
// 2. Es la página de inicio (exacta)
// 3. Es una sub-ruta de la sección (evitando que "/" active todo)
const isActive = normalizedHref === normalizedPathname || 
                 (normalizedHref !== "" && normalizedPathname.startsWith(normalizedHref as string));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>

<style>
	a {
		display: inline-block;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	/* El estilo visual de "activo" para el texto */
	a.active {
		font-weight: 900; /* Un poco más de peso para el estilo brutalista */
		color: #000;
	}

	/* Opcional: un ligero cambio de color en hover si no está activo */
	a:not(.active):hover {
		color: #ff0000;
	}
</style>