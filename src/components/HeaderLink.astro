---
import type { HTMLAttributes } from 'astro:types';

type Props = HTMLAttributes<'a'> & {
    activeFor?: string[];
};

const { href, class: className, activeFor = [], ...props } = Astro.props;
const { pathname } = Astro.url;

// Lógica de detección limpia
const normalizedPath = pathname.replace(/\/$/, "") || "/";
const normalizedHref = (href as string).replace(/\/$/, "") || "/";
const activePaths = [normalizedHref, ...activeFor.map((path) => path.replace(/\/$/, "") || "/")];
const isActive = activePaths.some((path) =>
    normalizedPath === path || (path !== '/' && normalizedPath.startsWith(path))
);
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
    <slot />
</a>

<style>
    a {
        display: inline-block;
        text-decoration: none;
        color: #000;
        font-family: monospace;
        font-weight: bold;
        font-size: 0.85rem;
        text-transform: uppercase;
        transition: color 0.3s ease;
        /* ELIMINAMOS bordes, afters y paddings que puedan romper el layout */
        border: none !important;
        position: relative;
    }

    a::after {
        display: none !important; /* Matamos cualquier línea estática */
        content: none !important;
    }

    a.active {
        color: #ff0000;
    }

    a:hover {
        color: #ff0000;
    }
</style>
