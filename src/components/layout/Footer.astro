---
const today = new Date();
---

<footer>
    <div class="footer-inner">
        <div class="footer-head">
            <div>
                <span class="footer-mark">Chelén</span>
                <p>Nunca más una línea correcta.</p>
            </div>
            <a class="footer-contact" href="mailto:contacto@revistachelen.cl">contacto@revistachelen.cl</a>
        </div>

        <div class="footer-grid">
            <nav class="footer-group" aria-label="Navegación secundaria">
                <span>Revista</span>
                <a href="/revista">Portada escrita</a>
                <a href="/articulos">Articulos</a>
                <a href="/columnas">Columnas</a>
                <a href="/cartas">Cartas</a>
            </nav>

            <nav class="footer-group" aria-label="Archivo editorial">
                <span>Arte</span>
                <a href="/multimedia/arte">Indice de arte</a>
                <a href="/multimedia/grafica">Grafica</a>
                <a href="/poemas">Poemas</a>
                <a href="/publicaciones/cuadernillos">Cuadernillos</a>
            </nav>

            <div class="footer-group">
                <span>Comunidad</span>
                <a href="/acerca/nosotros">Nosotros</a>
                <a href="/temas">Temas</a>
                <a href="/multimedia/audiovisual">Audiovisual</a>
                <a href="/buscar">Buscar</a>
                <a href="https://instagram.com/revista.chelen" target="_blank" rel="noreferrer">Instagram</a>
                <a href="mailto:contacto@revistachelen.cl">Correo</a>
            </div>
        </div>

        <div class="footer-bottom">
            <span>&copy; {today.getFullYear()} — Santiago de Chile.</span>
            <span>Registro en construcción.</span>
        </div>
    </div>
</footer>

<style>
    footer {
        width: 100%;
        margin-top: 4rem;
        color: #111;
    }

    .footer-inner {
        width: min(1280px, calc(100% - 2rem));
        margin: 0 auto 1rem;
        border-top: 0.45rem solid #111;
        padding-top: 0.75rem;
    }

    .footer-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 2rem;
        align-items: start;
        border-bottom: 2px solid #111;
        padding-bottom: 1.25rem;
    }

    .footer-mark {
        font-family: 'Sifonn', sans-serif;
        font-size: clamp(2rem, 4vw, 3.4rem);
        text-transform: uppercase;
        line-height: 0.9;
        display: block;
    }

    .footer-head p {
        font-family: monospace;
        font-size: 0.78rem;
        text-transform: uppercase;
        color: #666;
        margin: 0.7rem 0 0;
    }

    .footer-contact {
        background: #111;
        color: #fff;
        font-family: monospace;
        font-size: 0.72rem;
        text-transform: uppercase;
        text-decoration: none;
        padding: 0.35rem 0.55rem;
        max-width: 100%;
        overflow-wrap: anywhere;
        transition: background 0.2s;
    }

    .footer-contact:hover {
        background: #ff0000;
        color: #fff;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        padding: 1.25rem 0;
        border-bottom: 1px solid #111;
    }

    .footer-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem 1rem;
        align-content: flex-start;
        min-width: 0;
    }

    .footer-group span {
        flex-basis: 100%;
        font-family: 'Sifonn', sans-serif;
        font-size: 1rem;
        line-height: 1;
        text-transform: uppercase;
        color: #111;
    }

    .footer-group a {
        color: #111;
        font-family: monospace;
        font-size: 0.72rem;
        text-transform: uppercase;
        text-decoration: none;
        border-bottom: 1px solid #111;
        transition: color 0.2s, border-color 0.2s;
    }

    .footer-group a:hover {
        color: #ff0000;
        border-color: #ff0000;
    }

    .footer-bottom {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 0.75rem;
        font-family: monospace;
        font-size: 0.68rem;
        color: #777;
        text-transform: uppercase;
    }

    @media (max-width: 820px) {
        .footer-head,
        .footer-grid {
            grid-template-columns: 1fr;
        }

        .footer-contact {
            width: fit-content;
        }

        .footer-bottom {
            flex-direction: column;
        }
    }
</style>
