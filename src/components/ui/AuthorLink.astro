---
import { getCollection } from 'astro:content';
import { authorSlug, resolveAuthorRef } from '../../lib/authorSlug';

interface Props {
	name?: string | { id: string };
	class?: string;
}

const { name, class: className } = Astro.props;

const columnistas = await getCollection('columnistas');
const authorId = resolveAuthorRef(name);
const cleanName = authorId || 'Anónimo';

// Buscar si el autor es un columnista registrado (por su ID o por su nombre completo slugificado)
const profile = columnistas.find(
	(c) => c.id === cleanName || authorSlug(c.data.name) === authorSlug(cleanName)
) ?? null;

const displayName = profile?.data.name ?? cleanName;
const slug = profile?.id ?? authorSlug(cleanName);

const isAnon = displayName.toLowerCase() === 'anónimo' || displayName.toLowerCase() === 'anonimo';
---

{isAnon ? (
	<span class:list={[className]}>{displayName}</span>
) : (
	<a href={`/autores/${slug}`} class:list={['author-link', className]} onclick="event.stopPropagation()">
		{displayName}
	</a>
)}

<style>
	.author-link {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid currentColor;
		transition: color 0.2s, border-color 0.2s;
	}

	.author-link:hover {
		color: #ff1321;
		border-color: #ff1321;
	}
</style>
