---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	/** Ancho máximo de referencia para srcset y layout responsivo. */
	width?: number;
	class?: string;
	loading?: 'lazy' | 'eager';
	fetchpriority?: 'high' | 'low' | 'auto';
	/** LCP / above-the-fold: eager + fetchpriority high. */
	priority?: boolean;
}

const {
	src,
	alt,
	width = 800,
	class: className,
	loading: loadingProp,
	fetchpriority: fetchpriorityProp,
	priority = false,
} = Astro.props;

const loading = loadingProp ?? (priority ? 'eager' : 'lazy');
const fetchpriority = fetchpriorityProp ?? (priority ? 'high' : undefined);
---

<Image
	src={src}
	alt={alt}
	width={width}
	class={className}
	loading={loading}
	fetchpriority={fetchpriority}
	decoding={priority ? 'sync' : 'async'}
/>
