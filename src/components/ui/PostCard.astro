---
import ContentImage from './ContentImage.astro';
import FormattedDate from './FormattedDate.astro';
import AuthorLink from './AuthorLink.astro';

const { post, isFeatured } = Astro.props;
---

<article class={`post-card ${isFeatured ? 'featured' : ''} ${!post.data.heroImage ? 'no-image' : ''}`}>
    <a href={`/revista/articulos/${post.id}/`} class="post-link">
        {post.data.heroImage && (
            <div class="img-container">
                <ContentImage src={post.data.heroImage} alt="" width={800} />
            </div>
        )}
        <div class="content-wrapper">
            <span class="post-category">{post.data.category || 'Artículo'}</span>
            <h4 class="title">{post.data.title}</h4>
            <div class="post-author-row">
                <AuthorLink name={post.data.author || 'Redacción'} />
            </div>
        </div>
    </a>
</article>

<style>
    .post-card {
        background-color: #fff;
        border: 2px solid #111;
        border-radius: 8px;
        box-shadow: 4px 4px 0px 0px #111;
        overflow: hidden;
        -webkit-mask-image: -webkit-radial-gradient(white, black);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        
        display: flex;
        flex-direction: column;
        
        /* --- PROPORCIÓN MATEMÁTICA PARA IMÁGENES 2:1 --- */
        aspect-ratio: 3 / 2; /* Tarjetas de grilla: sutil y equilibrado */
    }
    
    .post-card.featured,
    :global(.featured-item) .post-card {
        /* Destacada: formato cinemático que deja la imagen casi en 2:1 exacto al expandir el texto */
        aspect-ratio: 16 / 9; 
    }
    
    .post-card:hover { 
        transform: translate(-3px, -3px); 
        box-shadow: 6px 6px 0px 0px #ff0000;
        border-color: #ff0000;
    }
    
    .post-link { 
        text-decoration: none; 
        color: #111; 
        display: flex; 
        flex-direction: column; 
        height: 100%; 
    }
    
    .img-container { 
        border-bottom: 2px solid #111;
        overflow: hidden; 
        
        /* El contenedor de imagen actúa como amortiguador fluido */
        flex: 1 1 auto; 
        min-height: 0; 
        display: flex;
        transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }
    
    .img-container :global(img) { 
        width: 100%; 
        height: 100%; 
        object-fit: cover; /* Se come el mínimo margen necesario sin distorsionar */
        border-radius: 0;
        transform: scale(1.01);
        transition: transform 0.4s ease; 
    }

    .post-card:hover .img-container :global(img) {
        transform: scale(1.04); /* Zoom un poco más sutil para no desorientar con el cambio de ratio */
    }

    .content-wrapper { 
        padding: 1.25rem; 
        flex: 1 1 auto; 
        display: flex; 
        flex-direction: column; 
    }
    
    .post-card.no-image .content-wrapper {
        justify-content: center;
        text-align: center;
    }

    .post-card.no-image .post-author-row {
        margin-top: 2rem;
    }
    
    .post-card.no-image .title {
        font-size: 1.5rem;
    }
    
    .title {
        font-family: 'Sifonn', sans-serif;
        font-size: 1.2rem; 
        line-height: 1.2;
        text-transform: uppercase;
        color: #111;
        
        margin: 0.75rem 0 0.25rem 0;
        padding: 0;
        opacity: 1;
        transform: translateY(0);
        transition: color 0.3s ease;
    }
    
    .post-card.featured .title,
    :global(.featured-item) .post-card .title {
        font-size: 1.8rem; /* Título ligeramente más grande en la destacada */
    }

    .post-card:hover .title { 
        color: #ff0000;
    }
    
    .post-category { 
        background: #111; 
        color: #fff; 
        font-size: 0.7rem; 
        padding: 0.25rem 0.5rem; 
        width: fit-content;
        transition: background 0.2s;
    }

    .post-card:hover .post-category {
        background: #ff0000;
    }
    
    .post-author-row { 
        margin-top: auto; 
        border-top: 1px solid #111; 
        padding-top: 0.75rem; 
        display: flex; 
        justify-content: space-between; 
        font-family: monospace; 
        font-size: 0.7rem; 
    }
    
    .affiliation { 
        text-decoration: underline; 
        text-decoration-color: red; 
    }
</style>
