---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, affiliation, category } = Astro.props;

const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 6);
---

<html lang="es">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            :global(body) {
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 1200px;
                margin: 0 auto;
                padding: clamp(1rem, 5vw, 3rem) 5%;
                display: grid;
                grid-template-columns: 1fr 320px;
                gap: clamp(2rem, 5vw, 5rem);
                align-items: start;
                box-sizing: border-box;
            }

            article { 
                width: 100%;
                min-width: 0; /* Evita que el contenido rompa el grid */
            }

            /* --- HERO IMAGE OPTIMIZADA --- */
            .hero-image {
                width: 100%;
                margin-bottom: 2.5rem;
            }

            .hero-image img {
                width: 100%;
                height: auto;
                display: block;
                border: 3px solid #000;
                box-shadow: 10px 10px 0px #000;
                object-fit: cover;
            }

            /* --- SIDEBAR --- */
            .sidebar {
                position: sticky;
                top: 2rem;
                border-left: 2px solid #111;
                padding-left: 2rem;
            }

            .sidebar-title {
                font-family: 'Sifonn', sans-serif;
                font-size: 1.2rem;
                text-transform: uppercase;
                border-bottom: 4px solid #111;
                margin-bottom: 2rem;
                padding-bottom: 0.5rem;
            }

            .sidebar-list {
                display: flex;
                flex-direction: column;
                gap: 2.5rem;
            }

            .sidebar-item {
                text-decoration: none;
                color: inherit;
                display: grid;
                grid-template-columns: 100px 1fr;
                gap: 1.5rem;
                align-items: start;
            }

            .sidebar-media-box {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }

            .sidebar-date {
                background: #000;
                color: #fff;
                font-family: monospace;
                font-size: 0.6rem;
                padding: 2px 6px;
                text-transform: uppercase;
                align-self: flex-start;
                display: inline-block;
                line-height: 1;
            }

            .sidebar-media-box img {
                width: 100%;
                aspect-ratio: 1;
                object-fit: cover;
                display: block;
                border: 2px solid #111;
                transition: all 0.3s ease;
            }

            /* Hover States */
            .sidebar-item:hover img {
                transform: translate(3px, -3px);
                box-shadow: -4px 4px 0px #000;
                filter: saturate(1.3);
            }
            
            .sidebar-item:hover h4 {
                color: #ff0000;
            }

            /* --- RESPONSIVE --- */
            @media (max-width: 960px) {
                main { 
                    grid-template-columns: 1fr; 
                    padding-top: 1rem;
                }
                
                .sidebar {
                    position: static;
                    border-left: none;
                    border-top: 4px solid #111;
                    padding-left: 0;
                    padding-top: 3rem;
                    margin-top: 2rem;
                }

                .hero-image img {
                    box-shadow: 6px 6px 0px #000; /* Sombra más pequeña en móvil */
                }
            }

            @media (max-width: 480px) {
                .sidebar-item {
                    grid-template-columns: 80px 1fr;
                    gap: 1rem;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                {heroImage && (
                    <div class="hero-image">
                        <img src={heroImage} alt="" />
                    </div>
                )}
                
                <header class="header-content" style="border-bottom: 5px solid #000; padding-bottom: 2rem; margin-bottom: 3rem;">
                    {category && <span style="background:#000; color:#fff; padding:0.2rem 0.6rem; font-family:monospace; font-size:0.8rem; text-transform:uppercase; font-weight:bold;">{category}</span>}
                    <h1 style="font-family:'Sifonn'; font-size: clamp(2.2rem, 5vw, 4rem); text-transform:uppercase; line-height:0.9; margin: 1rem 0;">{title}</h1>
                    <div style="display:flex; justify-content:space-between; border-bottom:1px solid #000; padding:1rem 0; font-family:monospace; text-transform:uppercase; gap: 1rem;">
                        <span style="font-weight:bold; color:#ff0000;">Por {author || 'Redacción Chelén'}</span>
                        <span style="color:#666; text-align: right;">{affiliation}</span>
                    </div>
                    <p style="font-size: clamp(1.1rem, 3vw, 1.4rem); font-style:italic; margin-top:1.5rem; line-height:1.2;">{description}</p>
                </header>

                <div class="prose" style="font-size: 1.15rem; line-height: 1.6;">
                    <slot />
                </div>
            </article>

            <aside class="sidebar">
                <h3 class="sidebar-title">Otras Lecturas</h3>
                <div class="sidebar-list">
                    {posts.map((post) => (
                        <a href={`/blog/${post.id}/`} class="sidebar-item">
                            <div class="sidebar-media-box">
                                <div class="sidebar-date">
                                    <FormattedDate date={post.data.pubDate} />
                                </div>
                                {post.data.heroImage && (
                                    <img src={post.data.heroImage} alt="" />
                                )}
                            </div>
                            <div class="sidebar-text">
                                <h4 style="font-family:'Sifonn'; font-size:0.85rem; text-transform:uppercase; margin:0; line-height:1.1;">{post.data.title}</h4>
                                <div style="display:flex; flex-direction:column; gap:2px; margin-top:5px;">
                                    <span style="font-family:monospace; font-size:0.7rem; color:#ff0000; text-transform:uppercase; font-weight:bold;">{post.data.author || 'Redacción'}</span>
                                    {post.data.category && (
                                        <span style="font-family:monospace; font-size:0.65rem; color:#888; text-transform:uppercase;">— {post.data.category}</span>
                                    )}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </aside>
        </main>
        <Footer />
    </body>
</html>