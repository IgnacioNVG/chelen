---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, affiliation, category } = Astro.props;

// Obtener posts recientes para el sidebar
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 3rem 1rem;
				display: grid;
				grid-template-columns: 1fr 320px;
				gap: 5rem;
				align-items: start;
			}

			article { width: 100%; }

			/* --- SIDEBAR LIMPIO --- */
			.sidebar {
				position: sticky;
				top: 2rem;
				border-left: 2px solid #111;
				padding-left: 2rem;
			}

			.sidebar-title {
				font-family: 'Sifonn', sans-serif;
				font-size: 1.2rem;
				text-transform: uppercase;
				border-bottom: 4px solid #111;
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
			}

			.sidebar-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.sidebar-item {
				text-decoration: none;
				color: inherit;
				display: flex;
				gap: 1.2rem;
				align-items: center;
				padding-bottom: 0.5rem;
			}

			.sidebar-image-container {
				flex-shrink: 0;
				width: 70px;
				height: 70px;
				border: 2px solid #111; /* Solo borde sólido, sin redondeo ni sombras */
				background: #000;
				overflow: hidden;
			}

			.sidebar-image-container img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				filter: grayscale(100%);
				transition: filter 0.3s ease;
			}

			.sidebar-text {
				display: flex;
				flex-direction: column;
				gap: 0.2rem;
			}

			.sidebar-item h4 {
				font-family: 'Sifonn', sans-serif;
				font-size: 0.9rem;
				text-transform: uppercase;
				margin: 0;
				line-height: 1.1;
				letter-spacing: -0.01em;
			}

			.sidebar-date {
				font-family: monospace;
				font-size: 0.7rem;
				color: #666;
				text-transform: uppercase;
			}

			/* Hover State */
			.sidebar-item:hover img {
				filter: grayscale(0%);
			}
			.sidebar-item:hover h4 {
				color: #ff0000;
			}

			/* --- RESPONSIVE --- */
			@media (max-width: 960px) {
				main { grid-template-columns: 1fr; }
				.sidebar {
					position: static;
					border-left: none;
					border-top: 4px solid #111;
					padding-left: 0;
					padding-top: 3rem;
					margin-top: 2rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image" style="margin-bottom: 2rem;">
						<img src={heroImage} alt="" style="width:100%; border:3px solid #000; box-shadow: 10px 10px 0px #000;" />
					</div>
				)}
				
				<header class="header-content" style="border-bottom: 5px solid #000; padding-bottom: 2rem; margin-bottom: 3rem;">
					{category && <span style="background:#000; color:#fff; padding:0.2rem 0.6rem; font-family:monospace; font-size:0.8rem; text-transform:uppercase; font-weight:bold;">{category}</span>}
					<h1 style="font-family:'Sifonn'; font-size: clamp(2.2rem, 5vw, 4rem); text-transform:uppercase; line-height:0.9; margin: 1rem 0;">{title}</h1>
					<div style="display:flex; justify-content:space-between; border-bottom:1px solid #000; padding:1rem 0; font-family:monospace; text-transform:uppercase;">
						<span style="font-weight:bold; color:#ff0000;">Por {author || 'Redacción Chelén'}</span>
						<span style="color:#666;">{affiliation}</span>
					</div>
					<p style="font-size:1.4rem; font-style:italic; margin-top:1.5rem; line-height:1.2;">{description}</p>
				</header>

				<div class="prose" style="font-size: 1.15rem; line-height: 1.6;">
					<slot />
				</div>
			</article>

			<aside class="sidebar">
				<h3 class="sidebar-title">Otras Lecturas</h3>
				<div class="sidebar-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="sidebar-item">
							{post.data.heroImage && (
								<div class="sidebar-image-container">
									<img src={post.data.heroImage} alt="" />
								</div>
							)}
							<div class="sidebar-text">
								<div class="sidebar-date">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h4>{post.data.title}</h4>
							</div>
						</a>
					))}
				</div>
			</aside>
		</main>
		<Footer />
	</body>
</html>