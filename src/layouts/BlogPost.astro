---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, affiliation, category } = Astro.props;

// Obtener posts recientes para el sidebar
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 3rem 1rem;
				display: grid;
				/* Definimos la rejilla: contenido principal y sidebar */
				grid-template-columns: 1fr 320px;
				gap: 5rem;
				align-items: start;
			}

			article {
				width: 100%;
			}

			/* --- SIDEBAR --- */
			.sidebar {
				position: sticky;
				top: 2rem;
				border-left: 2px solid #111;
				padding-left: 2rem;
			}

			.sidebar-title {
				font-family: 'Sifonn', sans-serif;
				font-size: 1.4rem;
				text-transform: uppercase;
				border-bottom: 4px solid #111;
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
				letter-spacing: -0.02em;
			}

			.sidebar-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.sidebar-item {
				text-decoration: none;
				color: inherit;
				display: block;
			}

			.sidebar-item:hover h4 {
				color: #ff0000;
			}

			.sidebar-item h4 {
				font-family: 'Sifonn', sans-serif;
				font-size: 1.1rem;
				text-transform: uppercase;
				margin: 0.5rem 0 0 0;
				line-height: 1.1;
			}

			.sidebar-date {
				font-family: monospace;
				font-size: 0.75rem;
				color: #666;
				text-transform: uppercase;
			}

			/* --- ESTILOS DE ARTÍCULO (Mantenidos) --- */
			.hero-image img {
				width: 100%;
				height: auto;
				border: 3px solid #000;
				box-shadow: 10px 10px 0px #000;
				margin-bottom: 2rem;
			}

			.header-content h1 {
				font-family: 'Sifonn', sans-serif;
				font-size: clamp(2.5rem, 6vw, 4rem);
				text-transform: uppercase;
				line-height: 0.9;
				margin: 1rem 0;
			}

			.prose {
				font-size: 1.15rem;
				line-height: 1.6;
			}

			/* --- RESPONSIVE: COMPORTAMIENTO EN TELÉFONO --- */
			@media (max-width: 960px) {
				main {
					grid-template-columns: 1fr; /* Una sola columna */
					gap: 3rem;
				}

				.sidebar {
					/* En móviles, el contenido pasa abajo, entre el post y el footer */
					position: static;
					border-left: none;
					border-top: 4px solid #111;
					padding-left: 0;
					padding-top: 3rem;
					margin-top: 2rem;
				}
				
				/* Opcional: si prefieres ocultarlo totalmente en móviles, descomenta esto:
				.sidebar { display: none; } 
				*/
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt="" />
					</div>
				)}
				
				<header class="header-content">
					{category && <span style="background:#000; color:#fff; padding:0.2rem 0.6rem; font-family:monospace; font-size:0.8rem; text-transform:uppercase; font-weight:bold;">{category}</span>}
					<h1>{title}</h1>
					<div style="display:flex; justify-content:space-between; border-bottom:1px solid #000; padding:1rem 0; font-family:monospace; text-transform:uppercase;">
						<span style="font-weight:bold; color:#ff0000;">Por {author || 'Redacción Chelén'}</span>
						<span style="color:#666;">{affiliation}</span>
					</div>
					<p style="font-size:1.4rem; font-style:italic; margin-top:1.5rem; line-height:1.2;">{description}</p>
				</header>

				<div class="prose">
					<slot />
				</div>

				<section style="margin-top: 5rem; padding: 2rem; background:#f4f4f4; border: 4px solid #000; box-shadow: 10px 10px 0px #ff0000;">
					<h3 style="font-family:'Sifonn'; text-transform:uppercase; font-size:2rem; margin:0 0 1rem 0;">Participa y opina</h3>
					<p>¿Tienes una crítica o quieres proponer un tema? Escríbenos a <strong>contacto@chelen.cl</strong></p>
				</section>
			</article>

			<aside class="sidebar">
				<h3 class="sidebar-title">Otras Lecturas</h3>
				<div class="sidebar-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="sidebar-item">
							<div class="sidebar-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h4>{post.data.title}</h4>
						</a>
					))}
				</div>
			</aside>
		</main>
		<Footer />
	</body>
</html>