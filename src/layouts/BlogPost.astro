---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, affiliation, category } = Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 3rem);
				max-width: 960px;
				margin: 0 auto;
				padding: 3rem 0;
			}
			article {
				width: 100%;
			}
			
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border: 3px solid #000;
				filter: grayscale(20%);
				box-shadow: 10px 10px 0px #000;
			}

			.header-content {
				margin-bottom: 3rem;
				border-bottom: 5px solid #000;
				padding-bottom: 2rem;
			}

			.post-category {
				display: inline-block;
				background: #000;
				color: #fff;
				padding: 0.2rem 0.6rem;
				font-family: monospace;
				font-size: 0.8rem;
				text-transform: uppercase;
				margin-bottom: 1rem;
				font-weight: bold;
			}

			.header-content h1 {
				font-family: 'Sifonn', sans-serif;
				font-size: clamp(2.5rem, 8vw, 4.5rem);
				margin: 0.5rem 0;
				text-transform: uppercase;
				line-height: 0.9;
				letter-spacing: -1px;
			}

			/* FICHA TÉCNICA DEL AUTOR */
			.author-box {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				padding: 1rem 0;
				border-bottom: 1px solid #000;
				margin-bottom: 1.5rem;
				font-family: monospace;
				text-transform: uppercase;
			}

			.author-name {
				font-size: 1.1rem;
				font-weight: bold;
				color: #ff0000;
			}

			.author-affiliation {
				font-size: 0.85rem;
				color: #666;
				font-weight: bold;
			}

			.meta {
				font-family: monospace;
				font-size: 1rem;
				color: #000;
				text-transform: uppercase;
				font-weight: bold;
			}

			.description {
				font-size: 1.4rem;
				line-height: 1.2;
				color: #444;
				font-style: italic;
				margin-top: 1rem;
			}

			/* CONTENIDO MARKDOWN */
			.prose {
				width: 100%;
				line-height: 1.6;
				color: #1a1a1a;
			}

			:global(.prose p) {
				margin-bottom: 1.5rem;
				font-size: 1.15rem;
				text-align: justify;
			}

			:global(.prose h2, .prose h3) {
				font-family: 'Sifonn', sans-serif;
				text-transform: uppercase;
				margin: 2.5rem 0 1rem 0;
				line-height: 0.9;
			}

			:global(.prose h2) {
				font-size: 2.2rem;
				border-left: 8px solid #ff0000;
				padding-left: 1rem;
			}

			:global(.prose blockquote) {
				margin: 2rem 0;
				padding: 1.5rem 2rem;
				background: #f4f4f4;
				border-left: 10px solid #000;
				font-style: italic;
			}

			:global(.prose blockquote p) {
				margin-bottom: 0;
				font-size: 1.3rem;
				line-height: 1.2;
			}

			:global(.prose ul) {
				margin-bottom: 1.5rem;
				padding-left: 1.5rem;
			}

			:global(.prose li) {
				margin-bottom: 0.5rem;
				font-size: 1.15rem;
			}

			@media (max-width: 720px) {
				.author-box {
					flex-direction: column;
					gap: 0.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				
				<header class="header-content">
					{category && <span class="post-category">{category}</span>}
					
					<h1>{title}</h1>
					
					<div class="author-box">
						<span class="author-name">Por {author || 'Redacción Chelén'}</span>
						<span class="author-affiliation">{affiliation || 'FACSO UCh'}</span>
					</div>

					<div class="meta">
						[ <FormattedDate date={pubDate} /> ]
						{updatedDate && (
							<span> — ACTUALIZADO: <FormattedDate date={updatedDate} /></span>
						)}
					</div>

					<p class="description">{description}</p>
				</header>

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>