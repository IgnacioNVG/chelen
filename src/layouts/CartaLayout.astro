---
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ContentImage from '../components/ui/ContentImage.astro';
import FormattedDate from '../components/ui/FormattedDate.astro';
import AuthorLink from '../components/ui/AuthorLink.astro';
import { resolveAuthorRef } from '../lib/authorSlug';
import { SITE_TITLE } from '../consts';

const { title, pubDate, heroImage, author, affiliation } = Astro.props;
const authorId = resolveAuthorRef(author);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`${title} | ${SITE_TITLE}`} description={`Carta al Director: ${title}, por ${authorId ?? 'Redacción Chelén'}`} />
        <style>
            main {
                width: min(960px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 5rem;
            }

            .carta-layout {
                display: grid;
                grid-template-columns: minmax(160px, 260px) 1fr;
                gap: clamp(1.5rem, 3vw, 2.5rem);
                align-items: start;
            }

            .carta-layout--solo-texto {
                grid-template-columns: 1fr;
            }

            .breadcrumb {
                font-family: monospace;
                font-size: 0.72rem;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                margin-bottom: 1.5rem;
            }
            .breadcrumb a { color: #888; text-decoration: none; }
            .breadcrumb a:hover { color: #111; }

            .titulo-carta {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.5rem, 3vw, 2.4rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 0.5rem;
                color: #111;
            }

            .meta-info {
                font-family: monospace;
                font-size: 0.8rem;
                color: #888;
                margin-bottom: 1.2rem;
                padding-bottom: 1.2rem;
                border-bottom: 2px solid #111;
                display: flex;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            .affiliation-line {
                font-family: monospace;
                font-size: 0.78rem;
                font-weight: bold;
                color: #555;
                text-transform: uppercase;
                border-left: 4px solid #FF1321;
                padding-left: 0.7rem;
                margin-bottom: 1.8rem;
            }

            .cuerpo-carta {
                font-family: 'Raleway', sans-serif;
                font-size: 1.05rem;
                line-height: 1.75;
                color: #222;
                text-align: justify;
                hyphens: auto;
            }

            .cuerpo-carta p { margin-bottom: 1.2em; }
            .cuerpo-carta p:first-child { font-style: italic; }

            @media (max-width: 720px) {
                main { padding: 1.5rem 0 3rem; }
                .carta-layout { grid-template-columns: 1fr; }
                .titulo-carta { font-size: 1.4rem; }
                .cuerpo-carta { font-size: 0.97rem; text-align: left; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <article class:list={['carta-layout', !heroImage && 'carta-layout--solo-texto']}>
                {heroImage && (
                    <figure class="editorial-figure">
                        <ContentImage src={heroImage} alt={title} width={480} priority />
                    </figure>
                )}

                <div class="editorial-sheet">
                    <p class="breadcrumb">
                        <a href="/cartas">Cartas al Director</a> / Carta
                    </p>
                    <h1 class="titulo-carta">{title}</h1>
                    <div class="meta-info">
                        <span>Por: <AuthorLink name={author} /></span>
                        <span><FormattedDate date={pubDate} /></span>
                    </div>
                    {affiliation && (
                        <div class="affiliation-line">{affiliation}</div>
                    )}
                    <div class="cuerpo-carta">
                        <slot />
                    </div>
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
