---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { ImageMetadata } from 'astro';
import ContentImage from '../components/ContentImage.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	pubDate: Date;
	heroImage?: ImageMetadata;
	author: string;
	antologia?: string;
}

const { title, pubDate, heroImage, author, antologia } = Astro.props;
const mostrarPortada = !!heroImage && !antologia;
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`${title} | ${SITE_TITLE}`} description={`Poema: ${title}, por ${author}`} />
        <style>
            main {
                width: min(960px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 5rem;
            }

            .poema-layout {
                display: grid;
                grid-template-columns: minmax(160px, 280px) 1fr;
                gap: clamp(1.5rem, 3vw, 2.5rem);
                align-items: start;
            }

            .poema-layout--solo-texto {
                grid-template-columns: 1fr;
            }

            .aviso-antologia {
                font-family: monospace;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin-bottom: 1.5rem;
                padding: 0.6rem 0.8rem;
                border-left: 4px solid #ff1321;
                background: #f7f7f7;
            }

            .aviso-antologia a {
                color: #111;
                font-weight: bold;
            }

            .breadcrumb {
                font-family: monospace;
                font-size: 0.72rem;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                margin-bottom: 1.5rem;
            }
            .breadcrumb a { color: #888; text-decoration: none; }
            .breadcrumb a:hover { color: #111; }

            .titulo-poema {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.6rem, 3.5vw, 2.8rem);
                text-transform: uppercase;
                line-height: 1;
                margin: 0 0 0.5rem;
                color: #111;
            }

            .meta-info {
                font-family: monospace;
                font-size: 0.8rem;
                color: #888;
                margin-bottom: 2rem;
                padding-bottom: 1.2rem;
                border-bottom: 2px solid #111;
                display: flex;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            .cuerpo-poema {
                font-family: 'Raleway', sans-serif;
                font-size: 1.05rem;
                line-height: 1.9;
                color: #222;
                white-space: pre-line;
            }

            .cuerpo-poema p {
                white-space: pre-line;
                margin-bottom: 1.5em;
            }

            @media (max-width: 720px) {
                main { padding: 1.5rem 0 3rem; }
                .poema-layout { grid-template-columns: 1fr; }
                .titulo-poema { font-size: 1.5rem; }
                .cuerpo-poema { font-size: 1rem; line-height: 1.8; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <article class:list={['poema-layout', !mostrarPortada && 'poema-layout--solo-texto']}>
                {mostrarPortada && heroImage && (
                    <figure class="editorial-figure">
                        <ContentImage src={heroImage} alt={title} width={480} priority />
                    </figure>
                )}

                <div class="editorial-sheet">
                    {antologia && (
                        <p class="aviso-antologia">
                            Este poema forma parte de una antología.
                            <a href={`/poemas/antologia/${antologia}`}> Leer la antología completa →</a>
                        </p>
                    )}
                    <p class="breadcrumb">
                        <a href="/poemas">Poemas</a> / Poema
                    </p>
                    <h1 class="titulo-poema">{title}</h1>
                    <div class="meta-info">
                        <span>Por: {author}</span>
                        <span><FormattedDate date={pubDate} /></span>
                    </div>
                    <div class="cuerpo-poema">
                        <slot />
                    </div>
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
