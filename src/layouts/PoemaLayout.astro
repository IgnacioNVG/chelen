---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

const { title, pubDate, heroImage, author } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`${title} | ${SITE_TITLE}`} description={`Poema: ${title}, por ${author}`} />
        <style>
            /* ===== BASE ===== */
            main {
                width: min(960px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 5rem;
            }

            /* ===== LAYOUT PORTADA + TEXTO ===== */
            .poema-container {
                display: grid;
                grid-template-columns: 320px 1fr;
                gap: 0;
                border: 3px solid #111;
                min-height: 500px;
            }

            /* ===== COLUMNA IZQUIERDA: portada ===== */
            .portada-wrapper {
                position: relative;
                overflow: hidden;
                background: #111;
            }

            .portada-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                aspect-ratio: 4/5;
                display: block;
            }

            /* Cuando no hay imagen */
            .portada-fallback {
                width: 100%;
                aspect-ratio: 4/5;
                background: #111;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Sifonn', sans-serif;
                font-size: 4rem;
                color: rgba(255,255,255,0.1);
                letter-spacing: 0.2em;
            }

            /* ===== COLUMNA DERECHA: contenido ===== */
            .contenido-wrapper {
                padding: 2.5rem 3rem;
                border-left: 3px solid #111;
                display: flex;
                flex-direction: column;
            }

            .breadcrumb {
                font-family: monospace;
                font-size: 0.72rem;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                margin-bottom: 1.5rem;
            }
            .breadcrumb a { color: #888; text-decoration: none; }
            .breadcrumb a:hover { color: #111; }

            .titulo-poema {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.6rem, 3.5vw, 2.8rem);
                text-transform: uppercase;
                line-height: 1;
                margin: 0 0 0.5rem;
                color: #111;
            }

            .meta-info {
                font-family: monospace;
                font-size: 0.8rem;
                color: #888;
                margin-bottom: 2rem;
                padding-bottom: 1.2rem;
                border-bottom: 2px solid #111;
                display: flex;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            /* ===== CUERPO DEL POEMA ===== */
            .cuerpo-poema {
                font-family: 'Raleway', sans-serif;
                font-size: 1.05rem;
                line-height: 1.9;
                color: #222;
                /* Fundamental: respeta los saltos de línea del verso libre */
                white-space: pre-line;
                flex-grow: 1;
            }

            /* Si el autor escribió en markdown puro (párrafos) */
            .cuerpo-poema p {
                white-space: pre-line;
                margin-bottom: 1.5em;
            }

            /* ===== RESPONSIVE ===== */
            @media (max-width: 900px) {
                .poema-container { grid-template-columns: 240px 1fr; }
                .contenido-wrapper { padding: 2rem 2rem; }
            }

            @media (max-width: 720px) {
                main { padding: 1.5rem 0 3rem; }

                .poema-container {
                    grid-template-columns: 1fr;
                    border: 3px solid #111;
                }

                .portada-wrapper img {
                    /* En móvil usamos panorámico para no dominar la pantalla */
                    aspect-ratio: 4/3;
                    height: auto;
                    width: 100%;
                }
                .portada-fallback { aspect-ratio: 4/3; }

                .contenido-wrapper {
                    border-left: none;
                    border-top: 3px solid #111;
                    padding: 1.5rem 1.2rem;
                }

                .titulo-poema { font-size: 1.5rem; }
                .cuerpo-poema { font-size: 1rem; line-height: 1.8; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <article class="poema-container">
                <!-- Portada 4:5 -->
                <div class="portada-wrapper">
                    {heroImage
                        ? <img src={heroImage} alt={title} />
                        : <div class="portada-fallback">✦</div>
                    }
                </div>

                <!-- Poema -->
                <div class="contenido-wrapper">
                    <p class="breadcrumb">
                        <a href="/poemas">Poemas</a> / Poema
                    </p>
                    <h1 class="titulo-poema">{title}</h1>
                    <div class="meta-info">
                        <span>Por: {author}</span>
                        <span><FormattedDate date={pubDate} /></span>
                    </div>
                    <div class="cuerpo-poema">
                        <slot />
                    </div>
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>