---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const recursos = [
    { title: "Acceso Completo a la Carpeta Drive", type: "DIR", year: "2026", link: "https://drive.google.com/drive/folders/1QklUcvulfL0tdlG_COOHixlKLMdtGqW2" },
    { title: "Documento de Renovación Socialista", type: "PDF", year: "1985", link: "#" },
    { title: "Acta de Convergencia", type: "DOC", year: "1979", link: "#" },
];
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Archivo | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            :global(body) {
                margin: 0;
                padding: 0;
                overflow-x: hidden; 
            }

            main {
                width: 100%;
                max-width: 1200px;
                margin: 0 auto;
                padding: 2rem 5%;
                box-sizing: border-box;
            }

            .archive-container {
                border: 3px solid #000;
                background: #fafafa;
                padding: clamp(1rem, 5vw, 2.5rem);
                box-shadow: 8px 8px 0px #000;
            }

            .archive-header {
                border-bottom: 5px solid #000;
                margin-bottom: 2rem;
                padding-bottom: 1.5rem;
            }

            .archive-header h1 {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(2rem, 7vw, 4rem); 
                text-transform: uppercase;
                line-height: 0.9;
                margin: 0 0 1rem 0;
                letter-spacing: -0.02em;
            }

            .archive-header p {
                font-family: monospace;
                font-weight: bold;
                margin: 0;
                text-transform: uppercase;
                font-size: 0.9rem;
                color: #333;
            }

            .file-list {
                display: flex;
                flex-direction: column;
                gap: 0; /* Las líneas divisorias las da el borde inferior */
            }

            /* --- ESTRUCTURA DE FILA DINÁMICA --- */
            .file-row {
                display: flex;
                flex-wrap: wrap; /* Permite que los elementos bajen si no caben */
                align-items: center;
                gap: 1rem;
                border-bottom: 2px solid #000;
                padding: 1.5rem 0;
                font-family: monospace;
                transition: background 0.2s;
            }

            .file-row:hover {
                background: #f0f0f0;
            }

            /* Celdas específicas */
            .file-type-cell {
                flex: 0 0 70px;
            }

            .file-type {
                font-weight: bold;
                background: #000;
                color: #fff;
                text-align: center;
                padding: 4px 8px;
                font-size: 0.75rem;
                display: block;
            }

            .file-title {
                flex: 1 1 300px; /* Crece para ocupar espacio, mínimo 300px */
                font-weight: bold;
                text-transform: uppercase;
                font-size: 1.1rem;
                line-height: 1.2;
            }

            .file-year {
                flex: 0 0 80px;
                color: #666;
                text-align: center;
                font-weight: bold;
            }

            .btn-access-cell {
                flex: 0 1 200px;
                margin-left: auto; /* Empuja el botón a la derecha en desktop */
            }

            .btn-access {
                border: 2px solid #000;
                padding: 0.7rem 1rem;
                text-align: center;
                text-decoration: none;
                color: #000;
                font-weight: 900;
                font-size: 0.75rem;
                text-transform: uppercase;
                display: block;
                transition: all 0.2s;
            }

            .btn-access:hover {
                background: #000;
                color: #fff;
                transform: translate(-2px, -2px);
                box-shadow: 4px 4px 0px #ff0000;
            }

            .row-dir { background: #fff4f4; }

            /* --- AJUSTES PARA MÓVIL --- */
            @media (max-width: 768px) {
                .file-row {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 0.8rem;
                }

                .file-title {
                    flex: 1 1 auto;
                    width: 100%;
                }

                .btn-access-cell {
                    width: 100%;
                    margin-left: 0;
                }

                .file-year {
                    text-align: left;
                    font-size: 0.85rem;
                }

                .file-year::before {
                    content: "[AÑO: ";
                }
                .file-year::after {
                    content: "]";
                }

                .archive-container {
                    box-shadow: 4px 4px 0px #000;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div class="archive-container">
                <div class="archive-header">
                    <h1>Memoria Socialista</h1>
                    <p>Repositorio de bibliografía y contenido en difusión</p>
                </div>
                
                <div class="file-list">
                    {recursos.map((item) => (
                        <div class={`file-row ${item.type === 'DIR' ? 'row-dir' : ''}`}>
                            <div class="file-type-cell">
                                <span class="file-type">{item.type}</span>
                            </div>
                            
                            <div class="file-title">{item.title}</div>
                            
                            <div class="file-year">{item.year}</div>
                            
                            <div class="btn-access-cell">
                                <a href={item.link} target="_blank" class="btn-access">
                                    {item.type === 'DIR' ? 'Abrir Carpeta' : 'Descargar Archivo'}
                                </a>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </main>
        <Footer />
    </body>
</html>