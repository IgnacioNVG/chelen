---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

// 1. ¡AQUÍ ESTÁ LA MAGIA! Importamos tu nuevo componente pulido
import PostCard from '../../components/PostCard.astro'; 

const posts = (await getCollection('articulos')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = [...new Set(posts.map(post => post.data.category || 'Artículo'))];
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            main {
                width: 960px;
                max-width: calc(100% - 3rem);
                margin: 0 auto; 
                padding: 3rem 0;
            }

            .controls {
                margin-bottom: 3rem;
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                justify-content: space-between;
                align-items: center;
                border-bottom: 2px solid #000;
                padding-bottom: 1.5rem;
            }

            .filter-group { display: flex; gap: 0.5rem; flex-wrap: wrap; }

            button, select {
                background: #fff;
                border: 2px solid #000;
                padding: 0.4rem 0.8rem;
                font-family: monospace;
                font-size: 0.75rem;
                font-weight: bold;
                text-transform: uppercase;
                cursor: pointer;
            }

            button.active { background: #000; color: #fff; }

            /* --- 2. GRILLA PRINCIPAL LIMPIA --- */
            /* Ya no hay CSS de diseño aquí, solo estructura de grilla */
            ul {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 2.5rem;
                list-style: none;
                margin: 0;
                padding: 0;
            }

            /* Ocultar elementos filtrados por JS */
            ul li.hidden { display: none; }

            /* El JS le añade la clase 'featured-item' al primer elemento visible */
            ul li.featured-item {
                grid-column: span 2; /* Hace que ocupe las dos columnas */
            }

            @media (max-width: 720px) {
                ul { grid-template-columns: 1fr; }
                ul li.featured-item { grid-column: span 1; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div class="controls">
                <div class="filter-group">
                    <button class="filter-btn active" data-filter="all">Todos</button>
                    {categories.map(cat => (
                        <button class="filter-btn" data-filter={cat}>{cat}</button>
                    ))}
                </div>
                <select id="sort-select">
                    <option value="newest">Recientes primero</option>
                    <option value="oldest">Antiguos primero</option>
                </select>
            </div>

            <section>
                <ul id="post-list">
                    {posts.map((post) => (
                        <li class="post-item" 
                            data-category={post.data.category || 'Artículo'} 
                            data-date={post.data.pubDate.valueOf()}>
                            
                            {/* 3. REEMPLAZAMOS EL HTML POR EL COMPONENTE */}
                            <PostCard post={post} />

                        </li>
                    ))}
                </ul>
            </section>
        </main>
        <Footer />

        <script>
            // Tu script original queda intacto, gestionando quién es el destacado
            const postList = document.getElementById('post-list');
            const items = Array.from(document.querySelectorAll('.post-item'));
            const filterBtns = document.querySelectorAll('.filter-btn');
            const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;

            function update() {
                const filter = document.querySelector('.filter-btn.active')?.getAttribute('data-filter');
                const sort = sortSelect.value;

                items.forEach(el => {
                    const cat = el.getAttribute('data-category');
                    el.classList.toggle('hidden', filter !== 'all' && cat !== filter);
                });

                const visible = items.filter(el => !el.classList.contains('hidden'));
                visible.sort((a, b) => {
                    const da = parseInt(a.getAttribute('data-date')!);
                    const db = parseInt(b.getAttribute('data-date')!);
                    return sort === 'newest' ? db - da : da - db;
                });

                visible.forEach((el, index) => {
                    el.classList.toggle('featured-item', index === 0);
                    postList?.appendChild(el);
                });
            }

            filterBtns.forEach(btn => btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                update();
            }));

            sortSelect.addEventListener('change', update);
            update();
        </script>
    </body>
</html>