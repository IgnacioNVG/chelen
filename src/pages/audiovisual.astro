---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const sections = ['Podcast', 'Conversatorios', 'Paneles'];
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Audiovisual | ${SITE_TITLE}`} description="Podcast, conversatorios y paneles de Revista Chelen" />
        <style>
            main { width: min(1100px, calc(100% - 2rem)); margin: 0 auto; padding: 2.5rem 0 4rem; }
            .page-header { border-bottom: 4px solid #111; margin-bottom: 2rem; padding-bottom: 1rem; }
            h1 { font-size: clamp(2.3rem, 8vw, 5rem); text-transform: uppercase; line-height: 0.9; }
            .intro { max-width: 740px; color: #333; font-size: 1rem; line-height: 1.55; }
            .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
            .card { background: #fff; border: 2px solid #111; border-radius: 8px; box-shadow: 4px 4px 0 #111; padding: 1.25rem; min-height: 180px; display: flex; flex-direction: column; }
            .card h2 { font-size: 1.2rem; text-transform: uppercase; line-height: 1; }
            .card p { font-size: 0.9rem; line-height: 1.5; color: #444; margin-top: auto; }
            @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="page-header">
                <h1>Audiovisual</h1>
                <p class="intro">Una seccion independiente para alojar produccion sonora y audiovisual. La estructura queda lista para sumar nuevas categorias sin cambiar la navegacion principal.</p>
            </header>
            <section class="grid">
                {sections.map((section) => (
                    <article class="card">
                        <h2>{section}</h2>
                        <p>Archivo en preparacion.</p>
                    </article>
                ))}
            </section>
        </main>
        <Footer />
    </body>
</html>
