---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = [...new Set(posts.map(post => post.data.category || 'Artículo'))];
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            main {
                width: 960px;
                max-width: calc(100% - 3rem);
                margin: 0 auto; 
                padding: 3rem 0;
            }

            /* CONTROLES */
            .controls {
                margin-bottom: 3rem;
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                justify-content: space-between;
                align-items: center;
                border-bottom: 2px solid #000;
                padding-bottom: 1.5rem;
            }

            .filter-group { display: flex; gap: 0.5rem; flex-wrap: wrap; }

            button, select {
                background: #fff;
                border: 2px solid #000;
                padding: 0.4rem 0.8rem;
                font-family: monospace;
                font-size: 0.75rem;
                font-weight: bold;
                text-transform: uppercase;
                cursor: pointer;
            }

            button.active {
                background: #000;
                color: #fff;
            }

            /* GRILLA DE POSTS */
            ul {
                display: flex;
                flex-wrap: wrap;
                gap: 2.5rem;
                list-style-type: none;
                margin: 0;
                padding: 0;
            }

            ul li { 
                width: calc(50% - 1.25rem); 
                transition: transform 0.2s ease;
            }

            ul li.hidden { display: none; }

            /* ESTILO DESTACADO */
            ul li.featured-item {
                width: 100%;
                margin-bottom: 2rem;
            }
            ul li.featured-item img { filter: saturate(1.1) !important; } /* Un ligero toque base al destacado si deseas */
            ul li.featured-item .title { font-size: clamp(2.5rem, 6vw, 4rem); }

            /* CATEGORÍA */
            .post-category {
                background: #000;
                color: #fff;
                padding: 0.15rem 0.5rem;
                font-size: 0.7rem;
                font-family: monospace;
                text-transform: uppercase;
                border: 1px solid #000;
            }

            ul li img {
                width: 100%;
                margin-bottom: 1rem;
                border: 2px solid #000;
                /* Eliminado el grayscale(100%) */
                filter: saturate(1); 
                transition: all 0.2s ease;
            }

            .title {
                margin: 0.5rem 0;
                color: #000;
                font-family: 'Sifonn', sans-serif;
                line-height: 1;
                text-transform: uppercase;
                text-decoration: none; 
            }

            ul li a {
                text-decoration: none;
            }

            .post-info-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 0.5rem;
            }

            .date { font-family: monospace; font-size: 0.8rem; margin: 0; color: #000; }

            .post-author-row {
                margin-top: 0.5rem;
                padding-top: 0.5rem;
                border-top: 1px solid #eee;
                display: flex;
                justify-content: space-between;
                font-family: monospace;
                font-size: 0.75rem;
                color: #000;
            }

            /* HOVER - EFECTO DE SATURACIÓN +25% */
            ul li a:hover .title {
                text-decoration: none;
                color: #000;
            }

            ul li a:hover img {
                /* Sube la saturación un 25% */
                filter: saturate(1.25); 
                /* Sombra en negro para estilo brutalista */
                box-shadow: 8px 8px 0px #000; 
                transform: translate(-4px, -4px);
            }

            @media (max-width: 720px) {
                ul li { width: 100% !important; }
                .controls { flex-direction: column; gap: 1rem; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div class="controls">
                <div class="filter-group">
                    <button class="filter-btn active" data-filter="all">Todos</button>
                    {categories.map(cat => (
                        <button class="filter-btn" data-filter={cat}>{cat}</button>
                    ))}
                </div>
                <select id="sort-select">
                    <option value="newest">Recientes primero</option>
                    <option value="oldest">Antiguos primero</option>
                </select>
            </div>

            <section>
                <ul id="post-list">
                    {posts.map((post) => (
                        <li class="post-item" 
                            data-category={post.data.category || 'Artículo'} 
                            data-date={post.data.pubDate.valueOf()}>
                            <a href={`/blog/${post.id}/`}>
                                <img src={post.data.heroImage} alt="" />
                                <div class="post-info-row">
                                    <span class="post-category">{post.data.category || 'Artículo'}</span>
                                    <p class="date">[ <FormattedDate date={post.data.pubDate} /> ]</p>
                                </div>
                                <h4 class="title">{post.data.title}</h4>
                                <div class="post-author-row">
                                    <span>{post.data.author || 'Redacción'}</span>
                                    <span>{post.data.affiliation || 'UCh'}</span>
                                </div>
                            </a>
                        </li>
                    ))}
                </ul>
            </section>
        </main>
        <Footer />

        <script>
            const postList = document.getElementById('post-list');
            const items = Array.from(document.querySelectorAll('.post-item'));
            const filterBtns = document.querySelectorAll('.filter-btn');
            const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;

            function update() {
                const filter = document.querySelector('.filter-btn.active')?.getAttribute('data-filter');
                const sort = sortSelect.value;

                items.forEach(el => {
                    const cat = el.getAttribute('data-category');
                    el.classList.toggle('hidden', filter !== 'all' && cat !== filter);
                });

                const visible = items.filter(el => !el.classList.contains('hidden'));
                visible.sort((a, b) => {
                    const da = parseInt(a.getAttribute('data-date')!);
                    const db = parseInt(b.getAttribute('data-date')!);
                    return sort === 'newest' ? db - da : da - db;
                });

                visible.forEach((el, index) => {
                    el.classList.toggle('featured-item', index === 0);
                    postList?.appendChild(el);
                });
            }

            filterBtns.forEach(btn => btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                update();
            }));

            sortSelect.addEventListener('change', update);
            update();
        </script>
    </body>
</html>