---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContentImage from '../../components/ContentImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const cartas = (await getCollection('cartas')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Cartas al Director | ${SITE_TITLE}`} description="Espacio de debate y opinión ciudadana" />
        <style>
            main {
                width: min(960px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 4rem;
            }

            .seccion-header {
                font-family: monospace;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: #888;
                border-bottom: 1px solid #ccc;
                padding-bottom: 0.6rem;
                margin-bottom: 2.5rem;
            }

            .carta-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.3rem, 2.5vw, 2rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 0.8rem;
                color: #111;
            }

            .carta-meta {
                font-family: monospace;
                font-size: 0.76rem;
                color: #888;
                margin-bottom: 1rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.6rem;
            }

            .affiliation-tag {
                font-family: monospace;
                font-size: 0.74rem;
                font-weight: bold;
                color: #444;
                border-left: 4px solid #FF1321;
                padding-left: 0.6rem;
                margin-bottom: 1rem;
            }

            .leer-link {
                display: inline-block;
                margin-top: 0.5rem;
                font-family: monospace;
                font-size: 0.76rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #111;
                border-bottom: 2px solid #111;
                text-decoration: none;
                padding-bottom: 1px;
                transition: color 0.15s, border-color 0.15s;
            }
            .leer-link:hover { color: #FF1321; border-color: #FF1321; }

            .estado-vacio {
                text-align: center;
                padding: 3rem 0;
                font-family: monospace;
                color: #aaa;
                font-size: 0.9rem;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <p class="seccion-header">// Cartas al Director</p>

            {cartas.length === 0 && (
                <p class="estado-vacio">No hay cartas publicadas aún.</p>
            )}

            {cartas.map((carta) => (
                <a class="editorial-card-link" href={`/cartas/${carta.id}`}>
                    {carta.data.heroImage && (
                        <figure class="editorial-figure">
                            <ContentImage src={carta.data.heroImage} alt={carta.data.title} width={480} />
                        </figure>
                    )}
                    <div class="editorial-sheet editorial-sheet--compact">
                        <h2 class="carta-titulo">{carta.data.title}</h2>
                        <div class="carta-meta">
                            <span>{carta.data.author}</span>
                            <span>·</span>
                            <span><FormattedDate date={carta.data.pubDate} /></span>
                        </div>
                        {carta.data.affiliation && (
                            <div class="affiliation-tag">{carta.data.affiliation}</div>
                        )}
                        <span class="leer-link">Leer carta completa →</span>
                    </div>
                </a>
            ))}
        </main>
        <Footer />
    </body>
</html>
