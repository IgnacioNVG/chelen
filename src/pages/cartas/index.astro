---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContentImage from '../../components/ContentImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const cartas = (await getCollection('cartas')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Cartas al Director | ${SITE_TITLE}`} description="Espacio de debate y opinión ciudadana" />
        <style>
            main {
                width: min(1120px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 4rem;
            }

            .seccion-header {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.2rem, 2.5vw, 1.75rem);
                text-transform: uppercase;
                line-height: 1;
                color: #111;
                border-top: 0.45rem solid #111;
                padding-top: 0.5rem;
                margin: 0 0 1.5rem;
            }

            .cartas-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2rem;
            }

            .carta-card {
                background-color: #fff;
                border: 2px solid #111;
                border-radius: 8px;
                box-shadow: 4px 4px 0px 0px #111;
                overflow: hidden;
                -webkit-mask-image: -webkit-radial-gradient(white, black);
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                flex-direction: column;
                min-height: 100%;
                text-decoration: none;
                color: #111;
            }

            .carta-card:hover {
                transform: translate(-3px, -3px);
                box-shadow: 6px 6px 0px 0px #ff0000;
                border-color: #ff0000;
            }

            .carta-media {
                aspect-ratio: 4 / 5;
                margin: 0;
                background: #f5f5f5;
                border-bottom: 2px solid #111;
                padding: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                box-sizing: border-box;
            }

            .carta-media :global(img) {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 0;
                display: block;
                transform: scale(1.01);
                transition: transform 0.3s ease;
            }

            .carta-card:hover .carta-media :global(img) {
                transform: scale(1.06);
            }

            .carta-body {
                padding: 1.25rem;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

            .carta-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 0.35rem;
                margin-bottom: 0.75rem;
            }

            .carta-tag {
                font-family: monospace;
                font-size: 0.6rem;
                text-transform: uppercase;
                background: #eee;
                color: #333;
                padding: 0.15rem 0.4rem;
                transition: background 0.2s, color 0.2s;
            }

            .carta-tag--section {
                background: #111;
                color: #fff;
            }

            .carta-card:hover .carta-tag {
                background: #ff0000;
                color: #fff;
            }

            .carta-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.05rem, 1.6vw, 1.35rem);
                text-transform: uppercase;
                line-height: 1.1;
                margin: 0 0 0.75rem;
                color: #111;
            }

            .affiliation-tag {
                font-family: monospace;
                font-size: 0.68rem;
                font-weight: bold;
                color: #444;
                border-left: 3px solid #FF1321;
                padding-left: 0.5rem;
                margin: 0 0 1rem;
                line-height: 1.35;
            }

            .carta-meta {
                font-family: monospace;
                font-size: 0.65rem;
                color: #777;
                margin-top: auto;
                padding-top: 0.65rem;
                border-top: 1px solid #111;
                display: flex;
                flex-wrap: wrap;
                gap: 0.6rem;
            }

            .leer-link {
                display: inline-block;
                margin-top: 1rem;
                font-family: monospace;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #111;
                border-bottom: 2px solid #111;
                text-decoration: none;
                padding-bottom: 1px;
                align-self: flex-start;
                transition: color 0.2s, border-color 0.2s;
            }

            .carta-card:hover .leer-link {
                color: #ff0000;
                border-color: #ff0000;
            }

            .estado-vacio {
                text-align: center;
                padding: 3rem 0;
                font-family: monospace;
                color: #aaa;
                font-size: 0.9rem;
            }

            @media (max-width: 1024px) {
                .cartas-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (max-width: 720px) {
                .cartas-grid {
                    grid-template-columns: 1fr;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <p class="seccion-header">// Cartas al Director</p>

            {cartas.length === 0 && <p class="estado-vacio">No hay cartas publicadas aún.</p>}

            {cartas.length > 0 && (
                <div class="cartas-grid">
                    {cartas.map((carta) => (
                        <a class="carta-card" href={`/cartas/${carta.id}`}>
                            {carta.data.heroImage && (
                                <figure class="carta-media">
                                    <ContentImage src={carta.data.heroImage} alt={carta.data.title} width={480} />
                                </figure>
                            )}
                            <div class="carta-body">
                                <div class="carta-tags">
                                    <span class="carta-tag carta-tag--section">{carta.data.category}</span>
                                    {carta.data.tags.slice(0, 2).map((tag) => (
                                        <span class="carta-tag">{tag}</span>
                                    ))}
                                </div>
                                <h2 class="carta-titulo">{carta.data.title}</h2>
                                {carta.data.affiliation && <div class="affiliation-tag">{carta.data.affiliation}</div>}
                                <div class="carta-meta">
                                    <span>{carta.data.author}</span>
                                    <span><FormattedDate date={carta.data.pubDate} /></span>
                                </div>
                                <span class="leer-link">Leer carta completa →</span>
                            </div>
                        </a>
                    ))}
                </div>
            )}
        </main>
        <Footer />
    </body>
</html>
