---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';

// 1. CARGA DINÁMICA DE RECURSOS
const imageFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/grafica-*.{webp,png,jpg,jpeg}');
const textFiles = import.meta.glob('../assets/grafica-*.txt', {
	query: '?raw',
	import: 'default',
	eager: true,
});

const graphics = await Promise.all(
    Object.keys(imageFiles).map(async (path) => {
        const img = await imageFiles[path]();
        const fileName = path.split('/').pop()?.split('.')[0] || '';
        const graficaNumber = Number.parseInt(fileName.replace('grafica-', ''), 10) || 0;

        const txtPath = path.replace(/\.(webp|png|jpg|jpeg)$/, '.txt');
        const rawContent = (textFiles[txtPath] as string | undefined) ?? '';
        
        const parts = rawContent.split('\n').filter(p => p.trim() !== '');
        const title = parts[0] || fileName.replace('grafica-', 'Pieza ').replace('-', ' ');
        const desc = parts.slice(1).join(' ') || "Registro visual del archivo Chelén. Esta pieza forma parte de la colección editorial enfocada en la estética constructivista.";

        return {
            src: img.default,
            id: fileName.toUpperCase().replace('-', '_'),
            title: title.trim(),
            description: desc.trim(),
            fullPath: img.default.src,
            order: graficaNumber,
        };
    })
);

graphics.sort((a, b) => a.order - b.order);

const description = "Registro Visual / Revista Chelén";
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Material Gráfico | ${SITE_TITLE}`} description={description} />
        <!-- PRECARGA: link preload para todas las imágenes full-size -->
        {graphics.map((img) => (
            <link rel="preload" as="image" href={img.src.src} />
        ))}
        <style>
            main {
                width: 100%; max-width: 1440px; margin: 0 auto; padding: 2rem 2.5%; box-sizing: border-box;
            }

            .page-header { border-bottom: 4px solid #111; margin-bottom: 3rem; padding-bottom: 1rem; margin-left: 2.5%; margin-right: 2.5%; }
            .page-header h1 { font-family: 'Sifonn', sans-serif; font-size: clamp(2rem, 8vw, 4.5rem); text-transform: uppercase; margin: 0; letter-spacing: -0.02em; line-height: 0.9; }

            /* MASONRY GRID */
            .masonry-grid { 
                display: grid; 
                grid-template-columns: repeat(4, 1fr); 
                gap: 1.5rem; 
                width: 100%; 
            }

            .grid-item {
                position: relative; background-color: #111; cursor: pointer; height: fit-content;
                border: 2px solid #111; box-shadow: 4px 4px 0px 0px #111; border-radius: 8px; 
                overflow: hidden; -webkit-mask-image: -webkit-radial-gradient(white, black);
                transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            .grid-item img { width: 100%; height: auto; display: block; filter: saturate(1.1); border-radius: inherit; transform: scale(1.01); transition: transform 0.3s ease; }
            .grid-item:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0px 0px #ff0000; border-color: #ff0000; }
            .grid-item:hover img { transform: scale(1.06); }

            .caption { position: absolute; bottom: 0; left: 0; background: #111; padding: 0.3rem 0.6rem; font-family: monospace; font-size: 0.6rem; color: #fff; opacity: 0; transform: translateY(10px); transition: all 0.3s ease; z-index: 2; border-radius: 0 6px 0 0; }
            .grid-item:hover .caption { opacity: 1; transform: translateY(0); background: #ff0000; }

            /* ===== LIGHTBOX - SCALE FROM ORIGIN ===== */
            .lightbox {
                position: fixed; z-index: 9999; top: 0; left: 0; width: 100%; height: 100%;
                pointer-events: none; opacity: 0;
                background: rgba(0, 0, 0, 0);
                display: flex; justify-content: center; align-items: center;
                transition: background 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0s linear 0.45s;
            }

            .lightbox.active {
                pointer-events: auto; opacity: 1;
                background: rgba(0, 0, 0, 0.92);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                transition: background 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0s linear 0s;
            }

            .lightbox-container {
                display: flex; width: 90%; max-width: 1200px; height: 85vh;
                background: #fff; border: 4px solid #000; box-shadow: 15px 15px 0px #ff0000;
                overflow: hidden; position: relative;
                /* Animación: escalar desde el origen del click */
                transform: scale(0.3);
                opacity: 0;
                transform-origin: var(--origin-x, 50%) var(--origin-y, 50%);
                transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1), 
                            opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            }

            .lightbox.active .lightbox-container {
                transform: scale(1);
                opacity: 1;
            }

            /* Cierre: colapsar de vuelta */
            .lightbox.closing {
                pointer-events: none;
                background: rgba(0, 0, 0, 0);
                transition: background 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0s linear 0.4s;
            }
            .lightbox.closing .lightbox-container {
                transform: scale(0.15);
                opacity: 0;
                transition: transform 0.35s cubic-bezier(0.55, 0, 0.67, 0.52),
                            opacity 0.25s ease 0.1s;
            }

            .lightbox-main { 
                flex: 1; background: #f0f0f0; display: flex; align-items: center; 
                justify-content: center; padding: 2rem; position: relative; overflow: hidden; 
            }
            .lightbox-main img { 
                max-width: 100%; max-height: 100%; object-fit: contain; 
                /* La imagen ya está precargada, transición solo para cambios internos */
                transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1); 
            }
            .lightbox-main img.swapping { 
                opacity: 0; 
                transform: scale(0.92); 
            }

            /* ===== SIDEBAR MEJORADO ===== */
            .lightbox-sidebar { 
                width: 320px; background: #fff; border-left: 4px solid #000; 
                display: flex; flex-direction: column; padding: 0; box-sizing: border-box; 
                overflow: hidden;
            }

            .sidebar-info { 
                padding: 1.5rem 1.5rem 1rem; 
                flex-shrink: 0;
            }
            .sidebar-info h2 { 
                font-family: 'Sifonn', sans-serif; text-transform: uppercase; 
                margin: 0 0 0.8rem 0; font-size: 1.5rem; line-height: 1; 
                border-bottom: 3px solid #ff0000; padding-bottom: 0.5rem; 
                transition: opacity 0.2s ease;
            }
            .sidebar-info p { 
                font-family: monospace; font-size: 0.82rem; color: #444; 
                line-height: 1.5; margin-bottom: 0;
                transition: opacity 0.2s ease;
            }

            .sidebar-similar { 
                flex: 1; display: flex; flex-direction: column; 
                border-top: 2px solid #eee; overflow: hidden;
            }
            .similar-title { 
                font-family: 'Sifonn', sans-serif; font-size: 0.75rem; 
                text-transform: uppercase; padding: 1rem 1.5rem 0.6rem; 
                color: #999; margin: 0; flex-shrink: 0; letter-spacing: 0.05em;
            }

            .similar-grid { 
                display: grid; 
                grid-template-columns: repeat(3, 1fr); 
                gap: 6px; 
                padding: 0 1.5rem 1.5rem;
                overflow-y: auto;
                flex: 1;
                align-content: start;
            }

            .similar-thumb-wrapper { display: block; width: 100%; }
            .similar-thumb-wrapper.hidden { display: none; }

            .similar-grid img { 
                width: 100%; aspect-ratio: 1; object-fit: cover; 
                border: 2px solid #111; cursor: pointer; 
                border-radius: 4px;
                transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
                filter: grayscale(0.3);
            }
            .similar-grid img:hover { 
                transform: scale(1.08); 
                border-color: #ff0000; 
                box-shadow: 3px 3px 0px #ff0000;
                filter: grayscale(0);
            }

            .close-x { 
                position: absolute; top: 1rem; right: 1rem; width: 36px; height: 36px; 
                background: #000; color: #fff; border: none; cursor: pointer; 
                display: flex; align-items: center; justify-content: center; z-index: 100; 
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            }
            .close-x:hover { background: #ff0000; transform: rotate(90deg) scale(1.1); }
            .close-x svg { width: 20px; height: 20px; stroke: currentColor; }

            /* MEDIA QUERIES */
            @media (max-width: 1024px) {
                .masonry-grid { grid-template-columns: repeat(3, 1fr); }
            }

            @media (max-width: 768px) {
                main { padding: 1rem; }
                .page-header { margin-bottom: 1.5rem; }
                .masonry-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
                .grid-item { border-radius: 6px; box-shadow: 2px 2px 0px 0px #111; }
                
                /* LIGHTBOX MOBILE */
                .lightbox-container { 
                    flex-direction: column; 
                    height: 100%; 
                    width: 100%; 
                    max-width: 100%;
                    border: none;
                    box-shadow: none;
                }
                .lightbox-main { 
                    height: 50%; 
                    padding: 1rem; 
                    background: #111;
                }
                .lightbox-sidebar { 
                    width: 100%; 
                    height: 50%; 
                    border-left: none; 
                    border-top: 4px solid #000; 
                    border-radius: 20px 20px 0 0;
                    margin-top: -20px;
                    z-index: 2;
                }
                .sidebar-info { padding: 1.2rem 1.2rem 0.8rem; }
                .sidebar-info h2 { font-size: 1.2rem; }
                .sidebar-info p { font-size: 0.78rem; }
                .similar-grid { 
                    grid-template-columns: repeat(4, 1fr); 
                    padding: 0 1.2rem 1.2rem;
                }
                .close-x { 
                    top: 1rem; 
                    right: 1rem; 
                    background: rgba(0,0,0,0.5); 
                    backdrop-filter: blur(4px);
                    border-radius: 50%;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="page-header">
                <h1>Material Gráfico</h1>
            </header>

            <section class="masonry-grid">
                {graphics.map((img) => (
                    <div class="grid-item" 
                         data-full={img.src.src} 
                         data-title={img.title} 
                         data-desc={img.description}>
                        <Image src={img.src} alt={img.title} width={600} />
                        <div class="caption">{img.id}</div>
                    </div>
                ))}
            </section>

            <div id="lightbox" class="lightbox">
                <div class="lightbox-container" id="lightbox-container">
                    <button class="close-x" id="close-btn" aria-label="Cerrar">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="square"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                    
                    <div class="lightbox-main">
                        <img id="lightbox-img" src="" alt="" />
                    </div>

                    <aside class="lightbox-sidebar">
                        <div class="sidebar-info">
                            <h2 id="sidebar-title">TITULO</h2>
                            <p id="sidebar-desc">Descripción...</p>
                        </div>
                        <div class="sidebar-similar">
                            <p class="similar-title">Otras piezas</p>
                            <div class="similar-grid">
                                {graphics.map((g) => (
                                    <div class="similar-thumb-wrapper" data-thumb-src={g.src.src}>
                                        <img src={g.src.src} 
                                            alt={g.title} 
                                            class="similar-thumb" 
                                            data-full={g.src.src} 
                                            data-title={g.title} 
                                            data-desc={g.description} />
                                    </div>
                                ))}
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </main>
        <Footer />

        <script>
            const lightbox = document.getElementById('lightbox')!;
            const lightboxContainer = document.getElementById('lightbox-container')!;
            const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
            const sidebarTitle = document.getElementById('sidebar-title')!;
            const sidebarDesc = document.getElementById('sidebar-desc')!;
            const closeBtn = document.getElementById('close-btn')!;
            const thumbWrappers = document.querySelectorAll('.similar-thumb-wrapper');

            // ===== PRECARGA DE IMÁGENES =====
            // Creamos un cache de Image objects para que el browser las tenga en memoria
            const imageCache = new Map<string, HTMLImageElement>();
            
            document.querySelectorAll('.grid-item').forEach(item => {
                const src = (item as HTMLElement).dataset.full!;
                if (!imageCache.has(src)) {
                    const img = new Image();
                    img.src = src;
                    imageCache.set(src, img);
                }
            });

            // Variable para guardar el rect del elemento que abrió el lightbox
            let originRect: DOMRect | null = null;

            function setTransformOrigin(rect: DOMRect) {
                // Calcular el centro del elemento relativo al viewport como porcentaje
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const percX = (centerX / window.innerWidth) * 100;
                const percY = (centerY / window.innerHeight) * 100;
                lightboxContainer.style.setProperty('--origin-x', `${percX}%`);
                lightboxContainer.style.setProperty('--origin-y', `${percY}%`);
            }

            function updateContent(src: string, title: string, desc: string, animate = true) {
                // Actualizar thumbs: ocultar la actual
                thumbWrappers.forEach(wrapper => {
                    const w = wrapper as HTMLElement;
                    w.classList.toggle('hidden', w.dataset.thumbSrc === src);
                });

                if (animate && lightboxImg.src && lightboxImg.src !== src) {
                    // Transición suave al cambiar entre piezas dentro del lightbox
                    lightboxImg.classList.add('swapping');
                    setTimeout(() => {
                        lightboxImg.src = src;
                        lightboxImg.alt = title;
                        sidebarTitle.innerText = title;
                        sidebarDesc.innerText = desc;
                        // Forzar reflow y quitar la clase
                        requestAnimationFrame(() => {
                            lightboxImg.classList.remove('swapping');
                        });
                    }, 180);
                } else {
                    // Sin animación (apertura inicial o imagen ya cacheada)
                    lightboxImg.src = src;
                    lightboxImg.alt = title;
                    sidebarTitle.innerText = title;
                    sidebarDesc.innerText = desc;
                }
            }

            // ===== ABRIR LIGHTBOX DESDE EL GRID =====
            document.querySelectorAll('.grid-item').forEach(item => {
                item.addEventListener('click', () => {
                    const t = item as HTMLElement;
                    originRect = t.getBoundingClientRect();
                    setTransformOrigin(originRect);

                    // La imagen ya está precargada, carga instantánea
                    updateContent(t.dataset.full!, t.dataset.title!, t.dataset.desc!, false);
                    
                    // Forzar un reflow antes de activar para que CSS aplique el origen
                    lightboxContainer.offsetHeight;

                    lightbox.classList.remove('closing');
                    lightbox.classList.add('active');
                    document.body.style.overflow = 'hidden';
                });
            });

            // ===== NAVEGAR ENTRE PIEZAS DENTRO DEL LIGHTBOX =====
            document.querySelectorAll('.similar-thumb').forEach(thumb => {
                thumb.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const t = thumb as HTMLElement;
                    updateContent(t.dataset.full!, t.dataset.title!, t.dataset.desc!, true);
                });
            });

            // ===== CERRAR LIGHTBOX CON ANIMACIÓN DE COLAPSO =====
            function closeLightbox() {
                lightbox.classList.remove('active');
                lightbox.classList.add('closing');
                document.body.style.overflow = '';

                // Esperar a que termine la animación de cierre
                const onEnd = () => {
                    lightbox.classList.remove('closing');
                    lightboxContainer.removeEventListener('transitionend', onEnd);
                };
                lightboxContainer.addEventListener('transitionend', onEnd);

                // Fallback por si transitionend no dispara
                setTimeout(() => lightbox.classList.remove('closing'), 450);
            }

            closeBtn.addEventListener('click', closeLightbox);
            lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && lightbox.classList.contains('active')) closeLightbox(); });
        </script>
    </body>
</html>