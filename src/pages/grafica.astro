---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';

// 1. CARGA DINÁMICA DE RECURSOS
const imageFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/grafica-*.{webp,png,jpg,jpeg}');
const textFiles = import.meta.glob('../assets/grafica-*.txt', { as: 'raw', eager: true });

const graphics = await Promise.all(
    Object.keys(imageFiles).map(async (path) => {
        const img = await imageFiles[path]();
        const fileName = path.split('/').pop()?.split('.')[0] || '';
        
        const txtPath = path.replace(/\.(webp|png|jpg|jpeg)$/, '.txt');
        const rawContent = textFiles[txtPath] || "";
        
        const parts = rawContent.split('\n').filter(p => p.trim() !== '');
        const title = parts[0] || fileName.replace('grafica-', 'Pieza ').replace('-', ' ');
        const desc = parts.slice(1).join(' ') || "Registro visual del archivo Chelén. Esta pieza forma parte de la colección editorial enfocada en la estética constructivista.";

        return {
            src: img.default,
            id: fileName.toUpperCase().replace('-', '_'),
            title: title.trim(),
            description: desc.trim(),
            fullPath: img.default.src
        };
    })
);

graphics.sort((a, b) => a.src.src.localeCompare(b.src.src));

const description = "Registro Visual / Revista Chelén";
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Material Gráfico | ${SITE_TITLE}`} description={description} />
        <style>
            main {
                width: 100%; max-width: 1440px; margin: 0 auto; padding: 2rem 2.5%; box-sizing: border-box;
            }

            .page-header { border-bottom: 4px solid #111; margin-bottom: 3rem; padding-bottom: 1rem; margin-left: 2.5%; margin-right: 2.5%; }
            .page-header h1 { font-family: 'Sifonn', sans-serif; font-size: clamp(2rem, 8vw, 4.5rem); text-transform: uppercase; margin: 0; letter-spacing: -0.02em; line-height: 0.9; }

            /* MASONRY GRID - PINTEREST STYLE */
            .masonry-grid { 
                display: grid; 
                grid-template-columns: repeat(4, 1fr); 
                gap: 1.5rem; 
                width: 100%; 
            }

            .grid-item {
                position: relative; background-color: #111; cursor: pointer; height: fit-content;
                border: 2px solid #111; box-shadow: 4px 4px 0px 0px #111; border-radius: 8px; 
                overflow: hidden; -webkit-mask-image: -webkit-radial-gradient(white, black);
                transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            .grid-item img { width: 100%; height: auto; display: block; filter: saturate(1.1); border-radius: inherit; transform: scale(1.01); transition: transform 0.3s ease; }
            .grid-item:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0px 0px #ff0000; border-color: #ff0000; }
            .grid-item:hover img { transform: scale(1.06); }

            .caption { position: absolute; bottom: 0; left: 0; background: #111; padding: 0.3rem 0.6rem; font-family: monospace; font-size: 0.6rem; color: #fff; opacity: 0; transform: translateY(10px); transition: all 0.3s ease; z-index: 2; border-radius: 0 6px 0 0; }
            .grid-item:hover .caption { opacity: 1; transform: translateY(0); background: #ff0000; }

            /* LIGHTBOX */
            .lightbox {
                display: none; position: fixed; z-index: 9999; top: 0; left: 0; width: 100%; height: 100%;
                background: rgba(0, 0, 0, 0.95); backdrop-filter: blur(8px);
                justify-content: center; align-items: center;
            }

            .lightbox.active { display: flex; }

            .lightbox-container {
                display: flex; width: 90%; max-width: 1200px; height: 85vh;
                background: #fff; border: 4px solid #000; box-shadow: 15px 15px 0px #ff0000;
                overflow: hidden; position: relative;
            }

            .lightbox-main { flex: 1; background: #f0f0f0; display: flex; align-items: center; justify-content: center; padding: 2rem; position: relative; overflow: hidden; }
            .lightbox-main img { max-width: 100%; max-height: 100%; object-fit: contain; transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
            .lightbox-main img.loading { opacity: 0; transform: scale(0.6); }

            .lightbox-sidebar { width: 320px; background: #fff; border-left: 4px solid #000; display: flex; flex-direction: column; padding: 1.5rem; box-sizing: border-box; overflow-y: auto; }
            .sidebar-info h2 { font-family: 'Sifonn', sans-serif; text-transform: uppercase; margin: 0 0 1rem 0; font-size: 1.6rem; line-height: 1; border-bottom: 3px solid #ff0000; padding-bottom: 0.5rem; }
            .sidebar-info p { font-family: monospace; font-size: 0.85rem; color: #333; line-height: 1.4; margin-bottom: 1.5rem; }

            .similar-title { font-family: 'Sifonn', sans-serif; font-size: 0.8rem; text-transform: uppercase; margin-bottom: 1rem; color: #999; }
            .similar-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
            .similar-thumb-wrapper { display: block; width: 100%; }
            .similar-thumb-wrapper.hidden { display: none; }
            .similar-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border: 2px solid #000; cursor: pointer; transition: all 0.2s; }
            .similar-grid img:hover { transform: scale(1.05); border-color: #ff0000; }

            .close-x { position: absolute; top: 1rem; right: 1rem; width: 36px; height: 36px; background: #000; color: #fff; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 100; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
            .close-x:hover { background: #ff0000; transform: rotate(90deg) scale(1.1); }
            .close-x svg { width: 20px; height: 20px; stroke: currentColor; }

            /* MEDIA QUERIES */
            @media (max-width: 1024px) {
                .masonry-grid { grid-template-columns: repeat(3, 1fr); }
            }

            @media (max-width: 768px) {
                main { padding: 1rem; }
                .page-header { margin-bottom: 1.5rem; }
                .masonry-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
                .grid-item { border-radius: 6px; box-shadow: 2px 2px 0px 0px #111; }
                
                /* LIGHTBOX MOBILE OPTIMIZATION */
                .lightbox-container { 
                    flex-direction: column; 
                    height: 100%; 
                    width: 100%; 
                    max-width: 100%;
                    border: none;
                    box-shadow: none;
                }
                .lightbox-main { 
                    height: 55%; 
                    padding: 1rem; 
                    background: #111; /* Fondo oscuro para resaltar la imagen */
                }
                .lightbox-sidebar { 
                    width: 100%; 
                    height: 45%; 
                    border-left: none; 
                    border-top: 4px solid #000; 
                    padding: 1.5rem; 
                    border-radius: 20px 20px 0 0; /* Aspecto de bottom sheet */
                    margin-top: -20px; /* Sobreposición sutil */
                    z-index: 2;
                }
                .close-x { 
                    top: 1rem; 
                    right: 1rem; 
                    background: rgba(0,0,0,0.5); 
                    backdrop-filter: blur(4px);
                    border-radius: 50%;
                }
                .sidebar-info h2 { font-size: 1.3rem; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="page-header">
                <h1>Material Gráfico</h1>
            </header>

            <section class="masonry-grid">
                {graphics.map((img) => (
                    <div class="grid-item" 
                         data-full={img.src.src} 
                         data-title={img.title} 
                         data-desc={img.description}>
                        <Image src={img.src} alt={img.title} width={600} />
                        <div class="caption">{img.id}</div>
                    </div>
                ))}
            </section>

            <div id="lightbox" class="lightbox">
                <div class="lightbox-container">
                    <button class="close-x" id="close-btn" aria-label="Cerrar">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="square"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                    
                    <div class="lightbox-main">
                        <img id="lightbox-img" src="" alt="" />
                    </div>

                    <aside class="lightbox-sidebar">
                        <div class="sidebar-info">
                            <h2 id="sidebar-title">TITULO</h2>
                            <p id="sidebar-desc">Descripción...</p>
                        </div>
                        <div class="sidebar-similar">
                            <p class="similar-title">Otras piezas</p>
                            <div class="similar-grid">
                                {graphics.map((g) => (
                                    <div class="similar-thumb-wrapper" data-thumb-src={g.src.src}>
                                        <img src={g.src.src} 
                                            alt={g.title} 
                                            class="similar-thumb" 
                                            data-full={g.src.src} 
                                            data-title={g.title} 
                                            data-desc={g.description} />
                                    </div>
                                ))}
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </main>
        <Footer />

        <script>
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
            const sidebarTitle = document.getElementById('sidebar-title');
            const sidebarDesc = document.getElementById('sidebar-desc');
            const closeBtn = document.getElementById('close-btn');
            const thumbWrappers = document.querySelectorAll('.similar-thumb-wrapper');

            function updateContent(src: string, title: string, desc: string) {
                if (!lightboxImg || !sidebarTitle || !sidebarDesc) return;

                thumbWrappers.forEach(wrapper => {
                    const w = wrapper as HTMLElement;
                    w.classList.toggle('hidden', w.dataset.thumbSrc === src);
                });

                lightboxImg.classList.add('loading');

                setTimeout(() => {
                    lightboxImg.src = src;
                    sidebarTitle.innerText = title;
                    sidebarDesc.innerText = desc;
                    
                    lightboxImg.onload = () => lightboxImg.classList.remove('loading');
                    setTimeout(() => lightboxImg.classList.remove('loading'), 100);
                }, 200);
            }

            document.querySelectorAll('.grid-item').forEach(item => {
                item.addEventListener('click', () => {
                    const t = item as HTMLElement;
                    updateContent(t.dataset.full!, t.dataset.title!, t.dataset.desc!);
                    lightbox?.classList.add('active');
                    document.body.style.overflow = 'hidden';
                });
            });

            document.querySelectorAll('.similar-thumb').forEach(thumb => {
                thumb.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const t = thumb as HTMLElement;
                    updateContent(t.dataset.full!, t.dataset.title!, t.dataset.desc!);
                });
            });

            const close = () => {
                lightbox?.classList.remove('active');
                document.body.style.overflow = '';
            };

            closeBtn?.addEventListener('click', close);
            lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
        </script>
    </body>
</html>