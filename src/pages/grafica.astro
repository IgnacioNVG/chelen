---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';

// Imports de imágenes
import img1 from '../assets/grafica-01.webp';
import img2 from '../assets/grafica-02.webp';
import img3 from '../assets/grafica-03.webp';
import img4 from '../assets/grafica-04.webp';
import img5 from '../assets/grafica-05.webp';
import img6 from '../assets/grafica-06.webp';
import img7 from '../assets/grafica-07.webp';

const graphics = [img1, img2, img3, img4, img5, img6, img7];
const description = "Registro Visual / Revista Chelén";
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Material Gráfico | ${SITE_TITLE}`} description={description} />
        <style>
            main {
                width: 100%;
                max-width: 1400px;
                margin: 0 auto;
                padding: 2rem 5%; /* Padding porcentual para mejor respuesta */
                box-sizing: border-box;
            }

            .page-header {
                border-bottom: 4px solid #111;
                margin-bottom: 3rem;
                padding-bottom: 1rem;
            }

            .page-header h1 {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(2.5rem, 8vw, 4.5rem); /* Tamaño dinámico */
                text-transform: uppercase;
                margin: 0;
                letter-spacing: -0.02em;
                line-height: 0.9;
            }

            /* GRID DINÁMICO BRUTALISTA */
            .masonry-grid {
                display: grid;
                /* auto-fill crea tantas columnas de mínimo 300px como quepan */
                grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                gap: 2.5rem;
                width: 100%;
            }

            .grid-item {
                position: relative;
                background-color: #000;
                cursor: zoom-in;
                height: fit-content;
                border: 3px solid #000;
                box-shadow: 8px 8px 0px 0px #000;
                transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                overflow: hidden; /* Evita que la imagen se salga antes del hover */
            }

            .grid-item img {
                width: 100%;
                height: auto;
                display: block;
                filter: saturate(1.1);
                transition: transform 0.3s ease;
            }

            .grid-item:hover {
                transform: translate(-4px, -4px);
                box-shadow: 12px 12px 0px 0px #ff0000;
            }

            .caption {
                position: absolute;
                bottom: 0;
                left: 0;
                background: #000;
                padding: 0.4rem 1rem;
                font-family: monospace;
                font-size: 0.75rem;
                color: #fff;
                opacity: 0;
                transform: translateY(10px);
                transition: all 0.3s ease;
                z-index: 2;
            }

            .grid-item:hover .caption {
                opacity: 1;
                transform: translateY(0);
            }

            /* LIGHTBOX */
            .lightbox {
                display: none;
                position: fixed;
                z-index: 9999;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.98);
                justify-content: center;
                align-items: center;
                padding: 1rem;
                box-sizing: border-box;
            }

            .lightbox.active { display: flex; }
            
            .lightbox img { 
                max-width: 95%; 
                max-height: 85vh; 
                object-fit: contain;
                border: 3px solid #fff; 
                box-shadow: 0px 0px 30px rgba(255, 0, 0, 0.2);
            }

            /* AJUSTES PARA MÓVILES PEQUEÑOS */
            @media (max-width: 480px) {
                .masonry-grid {
                    /* En pantallas muy pequeñas, bajamos el mínimo para que no rompa el ancho */
                    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                    gap: 1.5rem;
                }
                
                main {
                    padding: 1rem 4%;
                }

                .grid-item {
                    box-shadow: 5px 5px 0px 0px #000;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="page-header">
                <h1>Material Gráfico</h1>
            </header>

            <section class="masonry-grid">
                {graphics.map((img, index) => (
                    <div class="grid-item">
                        <Image src={img} alt={`Diseño Editorial ${index + 1}`} width={800} />
                        <div class="caption">ID_CHE_{String(index + 1).padStart(2, '0')}</div>
                    </div>
                ))}
            </section>

            <div id="lightbox" class="lightbox">
                <img id="lightbox-img" src="" alt="Gráfica ampliada" />
            </div>
        </main>
        <Footer />

        <script>
            const gridItems = document.querySelectorAll('.grid-item');
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

            gridItems.forEach(item => {
                item.addEventListener('click', () => {
                    const img = item.querySelector('img');
                    if (img && lightbox && lightboxImg) {
                        lightboxImg.src = (img as HTMLImageElement).src;
                        lightbox.classList.add('active');
                        document.body.style.overflow = 'hidden';
                    }
                });
            });

            lightbox?.addEventListener('click', () => {
                lightbox.classList.remove('active');
                document.body.style.overflow = '';
            });
        </script>
    </body>
</html>