---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';

// CARGA DINÁMICA: Busca todos los archivos webp, png, jpg o jpeg en la carpeta assets
const imageFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/grafica-*.{webp,png,jpg,jpeg}');

// Resolvemos las promesas de los imports para obtener los metadatos de las imágenes
const graphics = await Promise.all(
    Object.values(imageFiles).map((img) => img().then((res) => res.default))
);

// Ordenamos las imágenes (opcional, para mantener el orden por nombre de archivo)
graphics.sort((a, b) => a.src.localeCompare(b.src));

const description = "Registro Visual / Revista Chelén";
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Material Gráfico | ${SITE_TITLE}`} description={description} />
        <style>
            main {
                width: 100%;
                max-width: 1440px;
                margin: 0 auto;
                padding: 2rem 5%;
                box-sizing: border-box;
            }

            .page-header {
                border-bottom: 4px solid #111;
                margin-bottom: 3rem;
                padding-bottom: 1rem;
            }

            .page-header h1 {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(2.5rem, 8vw, 4.5rem);
                text-transform: uppercase;
                margin: 0;
                letter-spacing: -0.02em;
                line-height: 0.9;
            }

            .masonry-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                gap: 2.5rem;
                width: 100%;
            }

            .grid-item {
                position: relative;
                background-color: #111; 
                cursor: zoom-in;
                height: fit-content;
                border: 3px solid #111; 
                box-shadow: 8px 8px 0px 0px #111;
                border-radius: 12px; 
                overflow: hidden; 
                -webkit-mask-image: -webkit-radial-gradient(white, black);
                transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            .grid-item img {
                width: 100%;
                height: auto;
                display: block;
                filter: saturate(1.1);
                border-radius: inherit;
                transform: scale(1.01);
                transition: transform 0.3s ease;
            }

            .grid-item:hover {
                transform: translate(-4px, -4px);
                box-shadow: 12px 12px 0px 0px #ff0000;
                border-color: #ff0000; 
            }

            .grid-item:hover img {
                transform: scale(1.06);
            }

            .caption {
                position: absolute;
                bottom: 0;
                left: 0;
                background: #111;
                padding: 0.4rem 1rem;
                font-family: monospace;
                font-size: 0.75rem;
                color: #fff;
                opacity: 0;
                transform: translateY(10px);
                transition: all 0.3s ease;
                z-index: 2;
                border-radius: 0 8px 0 0;
            }

            .grid-item:hover .caption {
                opacity: 1;
                transform: translateY(0);
                background: #ff0000;
            }

            /* LIGHTBOX */
            .lightbox {
                display: none;
                position: fixed;
                z-index: 9999;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.98);
                justify-content: center;
                align-items: center;
                padding: 1rem;
            }

            .lightbox.active { display: flex; }
            
            .lightbox img { 
                max-width: 95%; 
                max-height: 85vh; 
                object-fit: contain;
                border: 4px solid #fff;
                border-radius: 8px;
                box-shadow: 0px 0px 40px rgba(255, 0, 0, 0.3);
            }

            @media (max-width: 480px) {
                .masonry-grid {
                    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                    gap: 1.5rem;
                }
                .grid-item {
                    box-shadow: 5px 5px 0px 0px #111;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="page-header">
                <h1>Material Gráfico</h1>
            </header>

            <section class="masonry-grid">
                {graphics.map((img, index) => (
                    <div class="grid-item">
                        <Image src={img} alt={`Diseño Editorial ${index + 1}`} width={800} />
                        <div class="caption">ID_CHE_{String(index + 1).padStart(2, '0')}</div>
                    </div>
                ))}
            </section>

            <div id="lightbox" class="lightbox">
                <img id="lightbox-img" src="" alt="Gráfica ampliada" />
            </div>
        </main>
        <Footer />

        <script>
            const gridItems = document.querySelectorAll('.grid-item');
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

            gridItems.forEach(item => {
                item.addEventListener('click', () => {
                    const img = item.querySelector('img');
                    if (img && lightbox && lightboxImg) {
                        lightboxImg.src = (img as HTMLImageElement).src;
                        lightbox.classList.add('active');
                        document.body.style.overflow = 'hidden';
                    }
                });
            });

            lightbox?.addEventListener('click', () => {
                lightbox.classList.remove('active');
                document.body.style.overflow = '';
            });
        </script>
    </body>
</html>