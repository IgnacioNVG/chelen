---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
				<main class="home">
			<section class="hero">
				<div class="hero-left">
					<h1>
						PENSAMIENTO,<br />
						ESTÉTICA Y<br />
						ORGANIZACIÓN.
					</h1>
				</div>

				<div class="hero-right">
					<p>
						Chelén es un proyecto editorial independiente
						que cruza política, cultura y gráfica
						para construir imaginario colectivo.
					</p>

					<a href="/about">Sobre nosotros →</a>
				</div>
			</section>

			<section class="archive">
				<div class="archive-header">
					<h2>ÚLTIMAS PIEZAS</h2>
					<a href="/blog">Ver todo →</a>
				</div>

				<div class="grid">
					<div class="card">
						<img src="/poster1.jpg" alt="" />
					</div>

					<div class="card">
						<img src="/poster2.jpg" alt="" />
					</div>

					<div class="card">
						<img src="/poster3.jpg" alt="" />
					</div>

					<div class="card">
						<img src="/poster4.jpg" alt="" />
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		background: #f3f0ea;
		color: #111;
		font-family: sans-serif;
		margin: 0;
	}

	main {
		padding: 2rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 4rem;
		padding: 6rem 0;
		border-bottom: 1px solid #111;
	}

	.hero h1 {
		font-size: clamp(4rem, 10vw, 8rem);
		line-height: 0.9;
		margin: 0;
		font-weight: 900;
	}

	.hero-right {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2rem;
		font-size: 1.1rem;
		max-width: 400px;
	}

	.hero-right a {
		color: black;
		text-decoration: none;
		font-weight: bold;
	}

	.archive {
		padding-top: 2rem;
	}

	.archive-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}

	.archive-header a {
		text-decoration: none;
		color: black;
		font-weight: bold;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
	}

	.card img {
		width: 100%;
		display: block;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>