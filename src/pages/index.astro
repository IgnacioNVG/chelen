---
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import FeedCard from '../components/home/FeedCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import {
    buildAntologiaItems,
    buildArticuloItems,
    buildCartaItems,
    buildPoemaItems,
    mergeEditorialFeed,
    editionLabel,
} from '../lib/homeFeed';

const articulos = await getCollection('articulos');
const cartas = await getCollection('cartas');
const antologias = await getCollection('antologias');
const poemas = await getCollection('poemas');

const editorialFeed = mergeEditorialFeed(
    buildArticuloItems(articulos),
    buildCartaItems(cartas),
    buildPoemaItems(poemas),
    buildAntologiaItems(antologias, poemas),
);

const edicion = editionLabel(editorialFeed);

const hero =
    editorialFeed.find((item) => item.kind === 'articulo' && item.imageLayout === 'landscape') ??
    editorialFeed[0];

const feedSinHero = editorialFeed.filter((item) => item.id !== hero?.id);
const publicacionesRecientes = feedSinHero.slice(0, 6);
const recientesIds = new Set([...publicacionesRecientes.map((d) => d.id), hero?.id].filter(Boolean));
const columnasRecientes = feedSinHero
    .filter((item) => item.kind === 'articulo' && !recientesIds.has(item.id))
    .slice(0, 3);
const cartasRecientes = feedSinHero.filter((item) => item.kind === 'carta').slice(0, 3);
const arteReciente = feedSinHero
    .filter((item) => item.kind === 'poema' || item.kind === 'antologia')
    .slice(0, 3);

const graphicFiles = import.meta.glob<{ default: ImageMetadata }>(
    '../assets/grafica-*.{webp,png,jpg,jpeg}',
);
const graphics = (
    await Promise.all(
        Object.keys(graphicFiles).map(async (path) => {
            const img = await graphicFiles[path]();
            const fileName = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
            const order = Number.parseInt(fileName.replace('grafica-', ''), 10) || 0;
            const title = fileName.replace('grafica-', 'Pieza ').replace(/-/g, ' ');
            return { id: fileName, title, src: img.default, order };
        }),
    )
).sort((a, b) => a.order - b.order);

const graficaDestacada = graphics.slice(-3).reverse();
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            .home {
                width: min(1280px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 1.5rem 0 4rem;
            }

            .masthead {
                border-bottom: 4px solid #111;
                padding-bottom: 1.25rem;
                margin-bottom: 2rem;
            }

            .masthead-kicker {
                font-family: monospace;
                font-size: 0.72rem;
                text-transform: uppercase;
                letter-spacing: 0.2em;
                color: #666;
                margin: 0 0 0.5rem;
            }

            .masthead-title {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(2.2rem, 6vw, 4rem);
                text-transform: uppercase;
                line-height: 0.95;
                margin: 0 0 0.35rem;
                color: #111;
            }

            .masthead-edition {
                font-family: monospace;
                font-size: 0.8rem;
                color: #444;
                margin: 0;
            }

            .section-band {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                border-top: 0.45rem solid #111;
                padding-top: 0.5rem;
                margin: 2.5rem 0 1.5rem;
            }

            .section-band h2 {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.2rem, 2.5vw, 1.75rem);
                text-transform: uppercase;
                margin: 0;
                color: #111;
            }

            .section-band a {
                font-family: monospace;
                font-size: 0.7rem;
                text-transform: uppercase;
                color: #111;
                text-decoration: none;
                border-bottom: 1px solid #111;
            }

            .section-band a:hover {
                color: #ff1321;
                border-color: #ff1321;
            }

            /* --- TARJETAS BRUTALISTAS (HERO, FEED Y GRÁFICA) --- */
            .hero-zone :global(.feed-card--hero),
            .feed-grid :global(.feed-card),
            .graphics-strip a {
                background-color: #fff;
                border: 2px solid #111;
                border-radius: 8px;
                box-shadow: 4px 4px 0px 0px #111;
                overflow: hidden;
                -webkit-mask-image: -webkit-radial-gradient(white, black);
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                flex-direction: column;
            }

            .hero-zone :global(.feed-card--hero:hover),
            .feed-grid :global(.feed-card:hover),
            .graphics-strip a:hover {
                transform: translate(-3px, -3px);
                box-shadow: 6px 6px 0px 0px #ff0000;
                border-color: #ff0000;
                background-color: #fff;
            }

            /* --- ESTRUCTURAS DE GRILLA --- */
            .hero-zone { margin-bottom: 2.5rem; }

            .hero-zone :global(.feed-card--hero .feed-card-link) {
                display: grid;
                grid-template-columns: 1.15fr 1fr;
                text-decoration: none;
                color: inherit;
            }

            /* Rejilla artículos (cabecera 2:1) */
            .feed-grid--articulos {
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 2rem; /* Separación amplia para permitir las sombras */
            }

            .feed-grid--articulos :global(.feed-card) {
                grid-column: span 4;
            }

            .feed-grid--articulos :global(.feed-card--featured) {
                grid-column: span 6;
            }

            /* Rejilla retrato (cartas, antología: 4:5) */
            .feed-grid--retrato {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2rem;
                margin-bottom: 2rem;
            }

            /* --- IMÁGENES Y ZOOM FLUIDO --- */
            .hero-zone :global(.feed-media--landscape) {
                aspect-ratio: 2 / 1;
                background: #f0f0f0;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                border-right: 2px solid #111;
            }

            .feed-grid :global(.feed-media--landscape) {
                aspect-ratio: 2 / 1;
                background: #f0f0f0;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                border-bottom: 2px solid #111;
            }

            .feed-grid :global(.feed-media--portrait) {
                aspect-ratio: 4 / 5;
                background: #f5f5f5;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                border-bottom: 2px solid #111;
                padding: 0;
                box-sizing: border-box;
            }

            .hero-zone :global(.feed-media--landscape img),
            .feed-grid :global(.feed-media--landscape img),
            .feed-grid :global(.feed-media--portrait img),
            .graphics-frame :global(img) {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                transform: scale(1.01);
                transition: transform 0.3s ease;
            }

            .hero-zone :global(.feed-card--hero:hover .feed-media--landscape img),
            .feed-grid :global(.feed-card:hover .feed-media--landscape img),
            .feed-grid :global(.feed-card:hover .feed-media--portrait img),
            .graphics-strip a:hover .graphics-frame :global(img) {
                transform: scale(1.06);
            }

            /* --- CONTENEDORES DE TEXTO --- */
            .feed-grid :global(.feed-card-link) {
                display: flex;
                flex-direction: column;
                height: 100%;
                text-decoration: none;
                color: inherit;
            }

            .hero-zone :global(.feed-card--hero .feed-body) {
                padding: clamp(1.25rem, 3vw, 2.5rem);
                display: flex;
                flex-direction: column;
            }

            .feed-grid :global(.feed-body) {
                padding: 1.25rem;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

            /* --- TIPOGRAFÍA Y ETIQUETAS --- */
            .hero-zone :global(.feed-title--hero) {
                font-size: clamp(1.6rem, 3.5vw, 2.8rem);
                font-family: 'Sifonn', sans-serif;
                text-transform: uppercase;
                line-height: 0.95;
                margin: 0 0 0.5rem;
                color: #111;
            }

            .feed-grid :global(.feed-title) {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(0.95rem, 1.4vw, 1.25rem);
                text-transform: uppercase;
                line-height: 1.1;
                margin: 0 0 0.5rem;
                color: #111;
            }

            .hero-zone :global(.feed-desc),
            .feed-grid :global(.feed-desc) {
                font-size: 0.85rem;
                line-height: 1.45;
                color: #444;
                margin: 0 0 0.75rem;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden;
                flex-grow: 1;
            }

            .hero-zone :global(.feed-desc) {
                font-size: 1rem;
                line-height: 1.55;
            }

            .feed-grid :global(.feed-tags),
            .hero-zone :global(.feed-tags) {
                display: flex;
                flex-wrap: wrap;
                gap: 0.35rem;
                margin-bottom: 0.6rem;
            }

            .feed-grid :global(.feed-tag),
            .hero-zone :global(.feed-tag) {
                font-family: monospace;
                font-size: 0.6rem;
                text-transform: uppercase;
                background: #eee;
                color: #333;
                padding: 0.15rem 0.4rem;
                transition: background 0.2s, color 0.2s;
            }

            .feed-grid :global(.feed-tag--section),
            .hero-zone :global(.feed-tag--section) {
                background: #111;
                color: #fff;
            }

            .feed-grid :global(.feed-card:hover .feed-tag),
            .hero-zone :global(.feed-card--hero:hover .feed-tag) {
                background: #ff0000;
                color: #fff;
            }

            .feed-grid :global(.feed-meta) {
                margin-top: auto;
                font-family: monospace;
                font-size: 0.65rem;
                color: #777;
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                padding-top: 0.6rem;
                border-top: 1px solid #111;
            }

            .feed-grid :global(.feed-author) {
                font-weight: bold;
                color: #111;
                border-left: 3px solid #ff1321;
                padding-left: 0.4rem;
            }

            /* --- ARCHIVO GRÁFICO (REDISEÑADO COMO CARDS) --- */
            .graphics-strip {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2rem;
            }

            .graphics-strip a {
                text-decoration: none;
                color: inherit;
                height: 100%;
            }

            .graphics-frame {
                aspect-ratio: 4 / 5;
                background: #f5f5f5;
                border-bottom: 2px solid #111;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
            }

            .graphics-content {
                padding: 1.25rem;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

            .graphics-content h4 {
                font-family: 'Sifonn', sans-serif;
                font-size: 0.9rem;
                text-transform: uppercase;
                margin: 0;
            }

            .graphics-content span {
                font-family: monospace;
                font-size: 0.62rem;
                color: #888;
                margin-top: 0.35rem;
            }

            .editorial-note {
                border: 2px solid #111;
                background: #fff;
                padding: clamp(1rem, 2vw, 1.5rem);
                max-width: 760px;
            }

            .editorial-note p {
                margin: 0;
                font-size: 0.95rem;
                line-height: 1.55;
                color: #333;
            }

            .editorial-note--compact {
                max-width: 620px;
            }

            /* --- RESPONSIVIDAD --- */
            @media (max-width: 1024px) {
                .feed-grid--articulos :global(.feed-card),
                .feed-grid--articulos :global(.feed-card--featured) {
                    grid-column: span 6;
                }
                .feed-grid--retrato {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (max-width: 720px) {
                .hero-zone :global(.feed-card--hero .feed-card-link) {
                    grid-template-columns: 1fr;
                }

                .hero-zone :global(.feed-media--landscape) {
                    border-right: none;
                    border-bottom: 2px solid #111;
                }

                .feed-grid--articulos :global(.feed-card),
                .feed-grid--articulos :global(.feed-card--featured) {
                    grid-column: span 12;
                }

                .feed-grid--retrato,
                .graphics-strip {
                    grid-template-columns: 1fr;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main class="home">
            <header class="masthead">
                <p class="masthead-kicker">"Organizar la Esperanza"</p>
                <h1 class="masthead-title">{SITE_TITLE}</h1>
                <p class="masthead-edition">
                    {SITE_DESCRIPTION}
                    {edicion && ` · ${edicion}`}
                </p>
            </header>

            {hero && (
                <section class="hero-zone">
                    <FeedCard item={hero} variant="hero" />
                </section>
            )}

            {publicacionesRecientes.length > 0 && (
                <>
                    <div class="section-band">
                        <h2>Publicaciones recientes</h2>
                        <a href="/revista">Ver publicaciones -></a>
                    </div>
                    <div class="feed-grid feed-grid--articulos">
                        {publicacionesRecientes.map((item) => (
                            <FeedCard item={item} variant="featured" />
                        ))}
                    </div>
                </>
            )}

            {columnasRecientes.length > 0 && (
                <>
                    <div class="section-band">
                        <h2>Columnas recientes</h2>
                        <a href="/revista/columnas">Ver columnas -></a>
                    </div>
                    <div class="feed-grid feed-grid--articulos">
                        {columnasRecientes.map((item) => (
                            <FeedCard item={item} />
                        ))}
                    </div>
                </>
            )}

            {arteReciente.length > 0 && (
                <>
                    <div class="section-band">
                        <h2>Arte socialista destacado</h2>
                        <a href="/multimedia/arte">Ver arte -></a>
                    </div>
                    <div class="feed-grid feed-grid--retrato">
                        {arteReciente.map((item) => (
                            <FeedCard item={item} />
                        ))}
                    </div>
                </>
            )}

            {graficaDestacada.length > 0 && (
                <>
                    <div class="section-band">
                        <h2>Grafica destacada</h2>
                        <a href="/multimedia/grafica">Ver todo -></a>
                    </div>
                    <div class="graphics-strip">
                        {graficaDestacada.map((g) => (
                            <a href="/multimedia/grafica">
                                <div class="graphics-frame">
                                    <Image src={g.src} alt={g.title} width={500} />
                                </div>
                                <div class="graphics-content">
                                    <h4>{g.title}</h4>
                                    <span>Formato 4:5 / Archivo visual</span>
                                </div>
                            </a>
                        ))}
                    </div>
                </>
            )}

            <div class="section-band">
                <h2>Produccion audiovisual reciente</h2>
                <a href="/multimedia/audiovisual">Ver audiovisual -></a>
            </div>
            <section class="editorial-note">
                <p>Podcast, conversatorios y paneles se agrupan en una seccion propia, preparada para incorporar nuevas categorias audiovisuales.</p>
            </section>

            {cartasRecientes.length > 0 && (
                <>
                    <div class="section-band">
                        <h2>Cartas al director</h2>
                        <a href="/revista/cartas">Ver cartas -></a>
                    </div>
                    <div class="feed-grid feed-grid--retrato">
                        {cartasRecientes.map((item) => (
                            <FeedCard item={item} />
                        ))}
                    </div>
                </>
            )}

            <div class="section-band">
                <h2>Cuadernillos</h2>
                <a href="/publicaciones/cuadernillos">Ver cuadernillos -></a>
            </div>
            <section class="editorial-note editorial-note--compact">
                <p>Publicaciones especiales con portada, autores, fecha, descarga PDF y lectura online.</p>
            </section>
        </main>
        <Footer />
    </body>
</html>
