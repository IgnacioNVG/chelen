---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

// Obtenemos los artículos y los ordenamos por fecha
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Separamos el contenido para la jerarquía visual
const featuredPost = posts[0];
const secondaryPosts = posts.slice(1, 4);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2em 1em;
				font-family: 'Atkinson', sans-serif;
			}
			
			/* Grilla editorial principal */
			.editorial-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 2rem;
				margin-bottom: 4rem;
			}

			/* Artículo destacado (ocupa más espacio) */
			.featured-article {
				grid-column: span 8;
				border-bottom: 2px solid #333; /* Líneas duras para separar contenido */
				padding-bottom: 2rem;
			}

			.featured-article img {
				width: 100%;
				height: auto;
				aspect-ratio: 16/9;
				object-fit: cover;
				margin-bottom: 1.5rem;
				filter: grayscale(100%); /* Opcional: un toque más sobrio/monocromático */
			}

			.featured-article h2 {
				font-size: 3rem;
				line-height: 1.1;
				margin: 0 0 1rem 0;
				letter-spacing: -0.02em;
			}

			/* Artículos secundarios (columna lateral) */
			.secondary-articles {
				grid-column: span 4;
				display: flex;
				flex-direction: column;
				gap: 2rem;
				border-left: 1px solid #ccc;
				padding-left: 2rem;
			}

			.secondary-item {
				border-bottom: 1px solid #eee;
				padding-bottom: 1.5rem;
			}

			.secondary-item:last-child {
				border-bottom: none;
			}

			.secondary-item h3 {
				font-size: 1.5rem;
				margin: 0.5rem 0;
				line-height: 1.2;
			}

			a {
				text-decoration: none;
				color: inherit;
			}

			a:hover {
				color: #555;
			}

			.meta {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: #666;
			}

			@media (max-width: 768px) {
				.editorial-grid {
					display: flex;
					flex-direction: column;
				}
				.secondary-articles {
					border-left: none;
					padding-left: 0;
					border-top: 2px solid #333;
					padding-top: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="editorial-grid">
				{featuredPost && (
					<article class="featured-article">
						<a href={`/blog/${featuredPost.slug}/`}>
							<img src={featuredPost.data.heroImage} alt="" />
							<div class="meta">
								<FormattedDate date={featuredPost.data.pubDate} />
							</div>
							<h2>{featuredPost.data.title}</h2>
							<p>{featuredPost.data.description}</p>
						</a>
					</article>
				)}

				<aside class="secondary-articles">
					{secondaryPosts.map((post) => (
						<article class="secondary-item">
							<a href={`/blog/${post.slug}/`}>
								<div class="meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h3>{post.data.title}</h3>
							</a>
						</article>
					))}
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>