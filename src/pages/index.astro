---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeedCard from '../components/home/FeedCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import {
	buildAntologiaItems,
	buildArticuloItems,
	buildCartaItems,
	mergeEditorialFeed,
	editionLabel,
} from '../lib/homeFeed';

const articulos = await getCollection('articulos');
const cartas = await getCollection('cartas');
const antologias = await getCollection('antologias');
const poemas = await getCollection('poemas');

const editorialFeed = mergeEditorialFeed(
	buildArticuloItems(articulos),
	buildCartaItems(cartas),
	buildAntologiaItems(antologias, poemas),
);

const edicion = editionLabel(editorialFeed);

const hero =
	editorialFeed.find((item) => item.kind === 'articulo' && item.imageLayout === 'landscape') ??
	editorialFeed[0];

const feedSinHero = editorialFeed.filter((item) => item.id !== hero?.id);
const destacados = feedSinHero.filter((item) => item.kind === 'articulo').slice(0, 2);
const restoIds = new Set([...destacados.map((d) => d.id), hero?.id].filter(Boolean));
const cronologiaResto = feedSinHero.filter((item) => !restoIds.has(item.id));

const retrato = cronologiaResto.filter((item) => item.kind === 'carta' || item.kind === 'antologia');
const articulosResto = cronologiaResto.filter((item) => item.kind === 'articulo');

const graphicFiles = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/grafica-*.{webp,png,jpg,jpeg}',
);
const graphics = (
	await Promise.all(
		Object.keys(graphicFiles).map(async (path) => {
			const img = await graphicFiles[path]();
			const fileName = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
			const order = Number.parseInt(fileName.replace('grafica-', ''), 10) || 0;
			const title = fileName.replace('grafica-', 'Pieza ').replace(/-/g, ' ');
			return { id: fileName, title, src: img.default, order };
		}),
	)
).sort((a, b) => a.order - b.order);

const graficaDestacada = graphics.slice(-3).reverse();
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home {
				width: min(1280px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.5rem 0 4rem;
			}

			.masthead {
				border-bottom: 4px solid #111;
				padding-bottom: 1.25rem;
				margin-bottom: 2rem;
			}

			.masthead-kicker {
				font-family: monospace;
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				color: #666;
				margin: 0 0 0.5rem;
			}

			.masthead-title {
				font-family: 'Sifonn', sans-serif;
				font-size: clamp(2.2rem, 6vw, 4rem);
				text-transform: uppercase;
				line-height: 0.95;
				margin: 0 0 0.35rem;
				color: #111;
			}

			.masthead-edition {
				font-family: monospace;
				font-size: 0.8rem;
				color: #444;
				margin: 0;
			}

			.hero-zone {
				margin-bottom: 2.5rem;
			}

			.hero-zone :global(.feed-card--hero) {
				border: 3px solid #111;
				background: #fff;
			}

			.hero-zone :global(.feed-card--hero .feed-card-link) {
				display: grid;
				grid-template-columns: 1.15fr 1fr;
				text-decoration: none;
				color: inherit;
			}

			.hero-zone :global(.feed-media--landscape) {
				aspect-ratio: 2 / 1;
				background: #f0f0f0;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				border-right: 3px solid #111;
			}

			.hero-zone :global(.feed-media--landscape img) {
				width: 100%;
				height: 100%;
				object-fit: contain;
				display: block;
			}

			.hero-zone :global(.feed-card--hero .feed-body) {
				padding: clamp(1.25rem, 3vw, 2.5rem);
				display: flex;
				flex-direction: column;
			}

			.hero-zone :global(.feed-title--hero) {
				font-size: clamp(1.6rem, 3.5vw, 2.8rem);
			}

			.hero-zone :global(.feed-desc) {
				font-size: 1rem;
				line-height: 1.55;
				color: #333;
				margin: 0 0 1rem;
				flex-grow: 1;
			}

			.section-band {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				border-top: 0.45rem solid #111;
				padding-top: 0.5rem;
				margin: 2.5rem 0 1.25rem;
			}

			.section-band h2 {
				font-family: 'Sifonn', sans-serif;
				font-size: clamp(1.2rem, 2.5vw, 1.75rem);
				text-transform: uppercase;
				margin: 0;
				color: #111;
			}

			.section-band a {
				font-family: monospace;
				font-size: 0.7rem;
				text-transform: uppercase;
				color: #111;
				text-decoration: none;
				border-bottom: 1px solid #111;
			}

			.section-band a:hover {
				color: #ff1321;
				border-color: #ff1321;
			}

			/* Rejilla artículos (cabecera 2:1) */
			.feed-grid--articulos {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 1px;
				background: #111;
				border: 1px solid #111;
			}

			.feed-grid--articulos :global(.feed-card) {
				background: #fff;
				grid-column: span 4;
			}

			.feed-grid--articulos :global(.feed-card--featured) {
				grid-column: span 6;
			}

			/* Rejilla retrato (cartas, antología: 4:5) */
			.feed-grid--retrato {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: #111;
				border: 1px solid #111;
				margin-bottom: 2rem;
			}

			.feed-grid--retrato :global(.feed-card) {
				background: #fff;
			}

			.feed-grid :global(.feed-card-link) {
				display: flex;
				flex-direction: column;
				height: 100%;
				text-decoration: none;
				color: inherit;
			}

			.feed-grid :global(.feed-card:hover) {
				background: #fafafa;
			}

			.feed-grid :global(.feed-media--landscape) {
				aspect-ratio: 2 / 1;
				background: #f0f0f0;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				border-bottom: 1px solid #111;
			}

			.feed-grid :global(.feed-media--landscape img) {
				width: 100%;
				height: 100%;
				object-fit: contain;
			}

			.feed-grid :global(.feed-media--portrait) {
				aspect-ratio: 4 / 5;
				background: #111;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				border-bottom: 1px solid #111;
				padding: 0.75rem;
				box-sizing: border-box;
			}

			.feed-grid :global(.feed-media--portrait img) {
				max-width: 100%;
				max-height: 100%;
				width: auto;
				height: auto;
				object-fit: contain;
				display: block;
			}

			.feed-grid :global(.feed-body) {
				padding: 1rem 1.1rem 1.2rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.feed-grid :global(.feed-tags) {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
				margin-bottom: 0.6rem;
			}

			.feed-grid :global(.feed-tag) {
				font-family: monospace;
				font-size: 0.6rem;
				text-transform: uppercase;
				background: #eee;
				color: #333;
				padding: 0.15rem 0.4rem;
			}

			.feed-grid :global(.feed-tag--section) {
				background: #111;
				color: #fff;
			}

			.feed-grid :global(.feed-title) {
				font-family: 'Sifonn', sans-serif;
				font-size: clamp(0.95rem, 1.4vw, 1.25rem);
				text-transform: uppercase;
				line-height: 1.1;
				margin: 0 0 0.5rem;
				color: #111;
			}

			.feed-grid :global(.feed-desc) {
				font-size: 0.85rem;
				line-height: 1.45;
				color: #444;
				margin: 0 0 0.75rem;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.feed-grid :global(.feed-meta) {
				margin-top: auto;
				font-family: monospace;
				font-size: 0.65rem;
				color: #777;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				padding-top: 0.6rem;
				border-top: 1px solid #eee;
			}

			.feed-grid :global(.feed-author) {
				font-weight: bold;
				color: #111;
				border-left: 3px solid #ff1321;
				padding-left: 0.4rem;
			}

			.hero-zone :global(.feed-tag) {
				font-family: monospace;
				font-size: 0.6rem;
				text-transform: uppercase;
				background: #eee;
				color: #333;
				padding: 0.15rem 0.4rem;
			}

			.hero-zone :global(.feed-tag--section) {
				background: #111;
				color: #fff;
			}

			.graphics-strip {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: #111;
				border: 1px solid #111;
			}

			.graphics-strip a {
				background: #fff;
				padding: 1.25rem;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
			}

			.graphics-strip a:hover {
				background: #fafafa;
			}

			.graphics-frame {
				aspect-ratio: 4 / 5;
				background: #f5f5f5;
				border: 2px solid #111;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				margin-bottom: 0.75rem;
			}

			.graphics-frame :global(img) {
				max-width: 100%;
				max-height: 100%;
				width: auto;
				height: auto;
				object-fit: contain;
			}

			.graphics-strip h4 {
				font-family: 'Sifonn', sans-serif;
				font-size: 0.9rem;
				text-transform: uppercase;
				margin: 0;
			}

			.graphics-strip span {
				font-family: monospace;
				font-size: 0.62rem;
				color: #888;
				margin-top: 0.35rem;
			}

			@media (max-width: 1024px) {
				.feed-grid--articulos :global(.feed-card),
				.feed-grid--articulos :global(.feed-card--featured) {
					grid-column: span 6;
				}
				.feed-grid--retrato {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 720px) {
				.hero-zone :global(.feed-card--hero .feed-card-link) {
					grid-template-columns: 1fr;
				}

				.hero-zone :global(.feed-media--landscape) {
					border-right: none;
					border-bottom: 3px solid #111;
				}

				.feed-grid--articulos :global(.feed-card),
				.feed-grid--articulos :global(.feed-card--featured) {
					grid-column: span 12;
				}

				.feed-grid--retrato,
				.graphics-strip {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="home">
			<header class="masthead">
				<p class="masthead-kicker">Número en curso</p>
				<h1 class="masthead-title">{SITE_TITLE}</h1>
				<p class="masthead-edition">
					{SITE_DESCRIPTION}
					{edicion && ` · ${edicion}`}
				</p>
			</header>

			{hero && (
				<section class="hero-zone">
					<FeedCard item={hero} variant="hero" />
				</section>
			)}

			{destacados.length > 0 && (
				<>
					<div class="section-band">
						<h2>En portada</h2>
						<a href="/articulos">Ver artículos →</a>
					</div>
					<div class="feed-grid feed-grid--articulos">
						{destacados.map((item) => (
							<FeedCard item={item} variant="featured" />
						))}
					</div>
				</>
			)}

			{retrato.length > 0 && (
				<>
					<div class="section-band">
						<h2>Cartas y antología</h2>
						<div>
							<a href="/cartas">Cartas →</a>
							{' '}
							<a href="/poemas">Poemas →</a>
						</div>
					</div>
					<div class="feed-grid feed-grid--retrato">
						{retrato.map((item) => (
							<FeedCard item={item} />
						))}
					</div>
				</>
			)}

			{articulosResto.length > 0 && (
				<>
					<div class="section-band">
						<h2>Crónica del número</h2>
						<a href="/articulos">Archivo completo →</a>
					</div>
					<div class="feed-grid feed-grid--articulos">
						{articulosResto.map((item) => (
							<FeedCard item={item} />
						))}
					</div>
				</>
			)}

			{graficaDestacada.length > 0 && (
				<>
					<div class="section-band">
						<h2>Archivo gráfico</h2>
						<a href="/grafica">Ver todo →</a>
					</div>
					<div class="graphics-strip">
						{graficaDestacada.map((g) => (
							<a href="/grafica">
								<div class="graphics-frame">
									<Image src={g.src} alt={g.title} width={500} />
								</div>
								<h4>{g.title}</h4>
								<span>Formato 4:5 · Archivo visual</span>
							</a>
						))}
					</div>
				</>
			)}
		</main>
		<Footer />
	</body>
</html>
