---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// 1. LLAMADA DINÁMICA AL BLOG
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Definimos las variables para el diseño escalable
const featuredPost = posts[0];
const otherPosts = posts.slice(1); // Esto evita el ReferenceError

// 2. LLAMADA DINÁMICA A LAS GRÁFICAS
import { Image } from 'astro:assets';
const graphicFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/*.{webp,png,jpg,jpeg}');
const graphics = await Promise.all(
	Object.keys(graphicFiles).map(async (path) => {
		const img = await graphicFiles[path]();
		const name = path.split('/').pop()?.split('.')[0] || 'Archivo Visual';
		return { src: img.default, name: name.replace('-', ' ') };
	})
);
const featuredGraphics = graphics.slice(0, 2);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			
			.section-header {
				border-bottom: 4px solid #111;
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
			}

			.section-header h2 {
				font-size: 2.5rem;
				text-transform: uppercase;
				margin: 0;
				letter-spacing: -0.02em;
				font-family: 'Sifonn', sans-serif;
			}

			.ver-mas {
				color: #111;
				font-weight: bold;
				text-decoration: none;
				text-transform: uppercase;
				font-size: 0.9rem;
			}

			/* --- GRID ORIGINAL --- */
			.columns-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 2px;
				background-color: #111;
				border: 2px solid #111;
				margin-bottom: 6rem;
			}

			.column-card {
				background-color: #fff;
				padding: 3rem 2rem;
				grid-column: span 6;
				display: flex;
				flex-direction: column;
				transition: background-color 0.2s ease;
				text-decoration: none;
				color: inherit;
			}

			.column-card.featured {
				grid-column: span 12;
			}

			.column-card:hover {
				background-color: #f4f4f4;
			}

			.column-card h3 {
				font-size: 2.5rem;
				text-transform: uppercase;
				line-height: 1;
				margin: 1rem 0;
				letter-spacing: -0.04em;
			}
			
			.column-card.featured h3 {
				font-size: 3.5rem;
			}

			.featured-content {
				display: flex;
				gap: 3rem;
				align-items: center;
			}

			.featured-image-container img {
				width: 320px;
				height: 320px;
				object-fit: cover;
				border: 4px solid #111;
				display: block;
			}

			.label {
				font-weight: bold;
				text-transform: uppercase;
				font-size: 0.85rem;
				background: #111;
				color: #fff;
				padding: 0.2rem 0.6rem;
				display: inline-block;
				margin-bottom: 1rem;
			}

			.meta-date {
				font-size: 0.9rem;
				text-transform: uppercase;
				color: #666;
				border-top: 1px solid #ccc;
				padding-top: 1rem;
				margin-top: auto;
			}

			/* --- GRÁFICAS ORIGINAL --- */
			.graphics-preview {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2.5rem;
				margin-bottom: 5rem;
			}

			.graphic-card {
				border: 1px solid #111;
				padding: 1.5rem;
				background: #fff;
				text-decoration: none;
				color: inherit;
			}

			.graphic-card img {
				width: 100%;
				height: auto;
				aspect-ratio: 4 / 5;
				object-fit: cover;
				border: 1px solid #111;
				margin-bottom: 1.5rem;
				display: block;
			}

			@media (max-width: 768px) {
				.featured-content { flex-direction: column; align-items: flex-start; }
				.column-card, .column-card.featured { grid-column: span 12; }
				.graphics-preview { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-box" style="margin-bottom: 3rem;">
				<p>
					Chelén es una publicación dedicada al análisis de la teoría social materialista y la marginalidad. <a href="/about">Acerca de</a>.
				</p>
			</section>

			<div class="section-header">
				<h2>Columnas Recientes</h2>
				<a href="/blog" class="ver-mas">Archivo Textual →</a>
			</div>
			
			<div class="columns-grid">
				{/* 1. EL DESTACADO (Siempre el más reciente) */}
				{featuredPost && (
					<a href={`/blog/${featuredPost.id}/`} class="column-card featured">
						<div class="featured-content">
							{featuredPost.data.heroImage && (
								<div class="featured-image-container">
									<img src={featuredPost.data.heroImage} alt="" />
								</div>
							)}
							<div class="featured-text">
								<span class="label">Última Publicación</span>
								<h3>{featuredPost.data.title}</h3>
								<p>{featuredPost.data.description}</p>
								<div class="meta-date">
									<FormattedDate date={featuredPost.data.pubDate} />
								</div>
							</div>
						</div>
					</a>
				)}

				{/* 2. EL RESTO (Se organizan en la rejilla original) */}
				{otherPosts.map((post) => (
					<a href={`/blog/${post.id}/`} class="column-card">
						<span class="label">Lectura</span>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
						<div class="meta-date">
							<FormattedDate date={post.data.pubDate} />
						</div>
					</a>
				))}
			</div>

			<div class="section-header">
				<h2>Gráficas Destacadas</h2>
				<a href="/grafica" class="ver-mas">Ver Archivo Gráfico →</a>
			</div>

			<div class="graphics-preview">
				{featuredGraphics.map((graphic, index) => (
					<a href="/grafica" class="graphic-card">
						<Image src={graphic.src} alt={graphic.name} width={800} />
						<div class="graphic-info">
							<span class="label">Composición 0{index + 1}</span>
							<h4 style="margin:0; text-transform: uppercase;">{graphic.name}</h4>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>