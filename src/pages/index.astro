---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Image } from 'astro:assets';

// Importamos un par de gráficas destacadas desde tus assets
import destacada1 from '../assets/grafica-01.webp';
import destacada2 from '../assets/grafica-02.webp';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			
			/* Encabezados de sección con rigor constructivista */
			.section-header {
				border-bottom: 4px solid #111;
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
			}

			.section-header h2 {
				font-size: 2.5rem;
				text-transform: uppercase;
				margin: 0;
				letter-spacing: -0.02em;
			}

			/* Texto de introducción con link al Acerca de */
			.intro-box {
				margin-bottom: 5rem;
				max-width: 900px;
			}

			.intro-box p {
				font-size: 1.75rem;
				line-height: 1.3;
				color: #111;
			}

			.intro-box a {
				color: #111;
				text-decoration: underline;
				text-decoration-thickness: 3px;
				font-weight: bold;
			}

			/* Grilla de Columnas Destacadas */
			.columns-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 2px;
				background-color: #111;
				border: 2px solid #111;
				margin-bottom: 6rem;
			}

			.column-card {
				background-color: #fff;
				padding: 3rem 2rem;
				grid-column: span 6;
				display: flex;
				flex-direction: column;
				transition: background-color 0.2s ease;
			}

			.column-card.featured {
				grid-column: span 12;
				border-bottom: 2px solid #111;
			}

			.column-card:hover {
				background-color: #f9f9f9;
			}

			.column-card h3 {
				font-size: 3.5rem;
				text-transform: uppercase;
				line-height: 0.95;
				margin: 1rem 0;
				letter-spacing: -0.04em;
			}

			.column-card.small h3 {
				font-size: 2rem;
			}

			.label {
				font-weight: bold;
				text-transform: uppercase;
				font-size: 0.85rem;
				background: #111;
				color: #fff;
				padding: 0.2rem 0.6rem;
				display: inline-block;
				align-self: flex-start;
			}

			/* Gráficas Destacadas (Preview) */
			.graphics-preview {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2.5rem;
				margin-bottom: 5rem;
			}

			.graphic-card {
				border: 1px solid #111;
				padding: 1.5rem;
				background: #fff;
			}

			.graphic-card img {
				width: 100%;
				height: auto;
				filter: grayscale(100%);
				border: 1px solid #111;
				margin-bottom: 1.5rem;
			}

			.graphic-card:hover img {
				filter: grayscale(0%);
			}

			.graphic-info h4 {
				text-transform: uppercase;
				margin: 0;
				font-size: 1.2rem;
			}

			@media (max-width: 900px) {
				.column-card, .column-card.featured {
					grid-column: span 12;
				}
				.graphics-preview {
					grid-template-columns: 1fr;
				}
				.column-card h3 {
					font-size: 2.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-box">
				<p>
					Chelén es una publicación dedicada al análisis de la teoría social materialista, la marginalidad y los procesos de organización comunitaria. Puedes leer más sobre nuestra visión editorial y equipo en la sección <a href="/about">Acerca de</a>.
				</p>
			</section>

			<div class="section-header">
				<h2>Columnas Destacadas</h2>
				<span>Crítica y Teoría</span>
			</div>
			
			<div class="columns-grid">
				<article class="column-card featured">
					<span class="label">Análisis Económico</span>
					<h3>Pague sus créditos, pague el plusvalor</h3>
					<p style="font-size: 1.2rem;">Una revisión sobre las dinámicas de endeudamiento y el papel del funcionario público Jorge Quiroz en la estructura institucional actual.</p>
				</article>

				<article class="column-card">
					<span class="label">Sociología</span>
					<h3 style="font-size: 2rem;">Producir la marginalidad</h3>
					<p>Apuntes sobre el simposio respecto a las condiciones del sistema penitenciario y la construcción de sujetos marginales.</p>
				</article>

				<article class="column-card">
					<span class="label">Territorio</span>
					<h3 style="font-size: 2rem;">Organización en Lo Hermida</h3>
					<p>Investigación cualitativa sobre las prácticas de articulación territorial y comunitaria entre 2020 y 2026.</p>
				</article>
			</div>

			<div class="section-header">
				<h2>Gráficas Destacadas</h2>
				<a href="/grafica" style="color: #111; font-weight: bold; text-decoration: none;">Ver archivo completo →</a>
			</div>

			<div class="graphics-preview">
				<div class="graphic-card">
					<Image src={destacada1} alt="Gráfica destacada 01" />
					<div class="graphic-info">
						<span class="label">Composición</span>
						<h4>Archivo Visual #01</h4>
					</div>
				</div>
				<div class="graphic-card">
					<Image src={destacada2} alt="Gráfica destacada 02" />
					<div class="graphic-info">
						<span class="label">Cartelería</span>
						<h4>Archivo Visual #02</h4>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>