---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const gridPosts = posts.slice(0, 8);

const graphicFiles = import.meta.glob<{ default: ImageMetadata }>('../assets/*.{webp,png,jpg,jpeg}');
const allGraphics = await Promise.all(
    Object.keys(graphicFiles).map(async (path) => {
        const img = await graphicFiles[path]();
        const name = path.split('/').pop()?.split('.')[0] || 'Archivo Visual';
        return { src: img.default, name: name.replace('-', ' ') };
    })
);

const randomGraphics = allGraphics
    .sort(() => Math.random() - 0.5)
    .slice(0, 3);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            main {
                width: 95%;
                max-width: 1440px;
                margin: 0 auto;
                padding: 2vw 0;
            }

            /* --- SECCIÓN HEADER --- */
            .section-header {
                border-top: 0.8vw solid #111;
                border-bottom: 2px solid #111;
                margin-top: 4vw;
                padding: 0.5rem 0;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: #111;
                color: #fff;
            }

            .section-header h2 {
                font-size: clamp(1.5rem, 3.5vw, 2.5rem);
                text-transform: uppercase;
                margin: 0;
                padding-left: 1rem;
                font-family: 'Sifonn', sans-serif;
                color: #fff !important;
            }

            /* --- CONTENEDORES --- */
            .flex-grid {
                display: flex;
                flex-wrap: wrap;
                background-color: #111;
                gap: 1px;
                border: 1px solid #111;
            }

            .graphics-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                background-color: #111;
                gap: 1px;
                border: 1px solid #111;
            }

            /* --- BLOG CARDS --- */
            .column-card {
                background-color: #fff;
                text-decoration: none;
                color: inherit;
                display: flex;
                flex-direction: column;
                flex: 1 1 calc(33.333% - 1px);
            }

            .column-card:nth-child(1), 
            .column-card:nth-child(2) {
                flex: 1 1 calc(50% - 1px);
            }

            .featured-cover {
                width: 100%;
                aspect-ratio: 16 / 9;
                overflow: hidden;
                border-bottom: 1px solid #111;
            }

            .featured-cover img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                /* RECTO: Al estar pegado al borde del contenedor oscuro */
                border-radius: 0 !important;
            }

            .card-inner {
                padding: 2vw;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

            /* --- SECCIÓN GRÁFICA --- */
            .graphic-item {
                background: #fff;
                padding: 2.5vw;
                text-decoration: none;
                color: inherit;
                display: flex;
                flex-direction: column;
            }

            .graphic-item img {
                width: 100%;
                aspect-ratio: 4 / 5;
                object-fit: contain;
                background-color: #f5f5f5;
                border: 1px solid #111;
                /* REDONDEADO: Al tener padding y no tocar los bordes del grid */
                border-radius: 8px !important;
                margin-bottom: 1.5rem;
                transition: transform 0.3s ease;
            }

            .graphic-item:hover img {
                transform: scale(1.02);
            }

            /* --- TIPOGRAFÍA Y TAGS --- */
            h3 { 
                text-transform: uppercase; 
                font-family: 'Sifonn', sans-serif; 
                margin: 0.5rem 0; 
                line-height: 1.1; 
                font-size: clamp(1.2rem, 2vw, 2rem);
            }

            .meta-row {
                margin-top: auto;
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .author-tag { 
                font-weight: 900; 
                text-transform: uppercase; 
                font-size: 0.7rem; 
                border-left: 4px solid #ff4d00; 
                padding-left: 0.6rem; 
            }

            .category-tag {
                font-family: monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                color: #888;
                font-weight: bold;
            }

            /* --- RESPONSIVE --- */
            @media (max-width: 1024px) {
                .column-card {
                    flex: 1 1 calc(50% - 1px);
                }
                .graphics-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (max-width: 650px) {
                .column-card {
                    flex: 1 1 100%;
                }
                .graphics-grid {
                    grid-template-columns: 1fr;
                }
                .graphic-item {
                    padding: 5vw;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section class="section-header">
                <h2>Publicaciones</h2>
            </section>
            
            <div class="flex-grid">
                {gridPosts.map((post, index) => (
                    <a href={`/blog/${post.id}/`} class="column-card">
                        {(index === 0 || index === 1) && post.data.heroImage && (
                            <div class="featured-cover">
                                <img src={post.data.heroImage} alt="" />
                            </div>
                        )}
                        <div class="card-inner">
                            <h3>{post.data.title}</h3>
                            <p style="font-size: 0.9rem; line-height: 1.4; color: #444; margin-bottom: 1.5rem;">{post.data.description}</p>
                            
                            <div class="meta-row">
                                <span class="author-tag">{post.data.author}</span>
                                {index > 1 && post.data.category && (
                                    <span class="category-tag">| {post.data.category}</span>
                                )}
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            <section class="section-header" style="background: #111; color: #111; border-top: 1vw solid #111;">
                <h2>Archivo Gráfico</h2>
            </section>

            <div class="graphics-grid">
                {randomGraphics.map((graphic) => (
                    <a href="/grafica" class="graphic-item">
                        <Image src={graphic.src} alt={graphic.name} width={800} />
                        <h4 style="margin: 0; font-size: 0.95rem; text-transform: uppercase; font-family: 'Sifonn';">{graphic.name}</h4>
                        <div style="width: 100%; font-family: monospace; font-size: 0.65rem; display: flex; justify-content: space-between; color: #777; border-top: 1px solid #eee; padding-top: 0.6rem; margin-top: 0.8rem;">
                            <span>FORMATO: 4:5</span>
                            <span>VER ARCHIVO</span>
                        </div>
                    </a>
                ))}
            </div>
        </main>
        <Footer />
    </body>
</html>