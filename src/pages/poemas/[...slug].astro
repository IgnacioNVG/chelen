---
import { getCollection, render } from 'astro:content';
import PoemaLayout from '../../layouts/PoemaLayout.astro';

export async function getStaticPaths() {
    const poemas = await getCollection('poemas');
    return poemas.map((poema) => ({
        params: { slug: poema.id },
        props: { poema },
    }));
}

const { poema } = Astro.props;
const { Content } = await render(poema);
---

<PoemaLayout {...poema.data}>
    <Content />
</PoemaLayout>