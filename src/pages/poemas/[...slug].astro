import { getCollection } from 'astro:content';
import PoemaLayout from '../../layouts/PoemaLayout.astro'; // O directamente aquí

export async function getStaticPaths() {
    const poemas = await getCollection('poemas');
    return poemas.map((poemas) => ({
        params: { slug: poema.id },
        props: poemas,
    }));
}

