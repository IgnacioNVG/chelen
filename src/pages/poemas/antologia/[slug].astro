---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ContentImage from '../../../components/ContentImage.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
    const antologias = await getCollection('antologias');
    return antologias.map((antologia) => ({
        params: { slug: antologia.id },
        props: { antologia },
    }));
}

const { antologia } = Astro.props;
const { Content } = await render(antologia);

const poemas = (await getCollection('poemas'))
    .filter((p) => p.data.antologia === antologia.id)
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const poemasRenderizados = await Promise.all(
    poemas.map(async (poema) => ({
        poema,
        ...(await render(poema)),
    }))
);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead
            title={`${antologia.data.title} | Antología | ${SITE_TITLE}`}
            description={antologia.data.description}
        />
        <style>
            main {
                width: min(1120px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 4rem;
            }

            .breadcrumb {
                font-family: monospace;
                font-size: 0.75rem;
                color: #777;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin: 0 0 0.9rem;
            }
            .breadcrumb a { color: #777; text-decoration: none; border-bottom: 1px solid #ccc; }
            .breadcrumb a:hover { color: #ff0000; border-color: #ff0000; }

            .antologia-badge {
                display: inline-block;
                background: #111;
                color: #fff;
                font-family: monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                padding: 0.2rem 0.5rem;
                margin-bottom: 1rem;
                transition: background 0.2s;
            }

            .antologia-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.8rem, 4vw, 3.2rem);
                text-transform: uppercase;
                line-height: 0.95;
                margin: 0 0 0.8rem;
                color: #111;
            }

            .antologia-descripcion {
                font-family: 'Raleway', sans-serif;
                font-size: 1rem;
                line-height: 1.7;
                color: #444;
                margin: 0 0 1.25rem;
            }

            .antologia-meta {
                font-family: monospace;
                font-size: 0.7rem;
                color: #777;
                border-top: 1px solid #111;
                padding-top: 0.75rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.65rem;
            }

            .antologia-intro {
                display: grid;
                grid-template-columns: minmax(280px, 0.72fr) 1fr;
                background-color: #fff;
                border: 2px solid #111;
                border-radius: 8px;
                box-shadow: 4px 4px 0px 0px #111;
                overflow: hidden;
                -webkit-mask-image: -webkit-radial-gradient(white, black);
                margin-bottom: 3rem;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            .antologia-intro:hover {
                transform: translate(-3px, -3px);
                box-shadow: 6px 6px 0px 0px #ff0000;
                border-color: #ff0000;
            }

            .antologia-intro:hover .antologia-badge {
                background: #ff0000;
            }

            .antologia-figure {
                aspect-ratio: 4 / 5;
                margin: 0;
                background: #f5f5f5;
                border-right: 2px solid #111;
                padding: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                box-sizing: border-box;
            }

            .antologia-figure :global(img) {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 0;
                display: block;
                transform: scale(1.01);
                transition: transform 0.3s ease;
            }

            .antologia-intro:hover .antologia-figure :global(img) {
                transform: scale(1.06);
            }

            .antologia-sheet {
                padding: clamp(1.25rem, 3vw, 2.5rem);
                display: flex;
                flex-direction: column;
            }

            .antologia-body {
                font-family: 'Raleway', sans-serif;
                font-size: 1rem;
                line-height: 1.7;
                color: #333;
                border-left: 3px solid #ff1321;
                padding-left: 1rem;
                margin-top: 2rem;
            }
            .antologia-body p { margin-bottom: 1em; }

            .seccion-header {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.2rem, 2.5vw, 1.75rem);
                text-transform: uppercase;
                line-height: 1;
                color: #111;
                border-top: 0.45rem solid #111;
                padding-top: 0.5rem;
                margin: 0 0 1.5rem;
            }

            .antologia-lectura {
                border: 2px solid #111;
                border-radius: 8px;
                box-shadow: 4px 4px 0px 0px #111;
                background: #fff;
                overflow: hidden;
            }

            .poema-bloque {
                padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3.5rem);
                border-bottom: 2px solid #111;
                transition: background 0.2s;
            }

            .poema-bloque:hover {
                background: #f5f5f5;
            }

            .poema-bloque:last-child {
                border-bottom: none;
            }

            .poema-bloque-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.3rem, 2.5vw, 1.9rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 0.6rem;
                color: #111;
            }

            .poema-bloque-titulo a {
                color: inherit;
                text-decoration: none;
            }

            .poema-bloque-titulo a:hover {
                color: #ff1321;
            }

            .poema-bloque-meta {
                font-family: monospace;
                font-size: 0.72rem;
                color: #777;
                margin-bottom: 1.5rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            .poema-bloque-cuerpo {
                font-family: 'Raleway', sans-serif;
                font-size: 1.05rem;
                line-height: 1.9;
                color: #222;
                white-space: pre-line;
            }

            .poema-bloque-cuerpo p {
                white-space: pre-line;
                margin-bottom: 1.5em;
            }

            .poema-enlace-permalink {
                display: inline-block;
                margin-top: 1.2rem;
                font-family: monospace;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #111;
                text-decoration: none;
                border-bottom: 2px solid #111;
            }

            .poema-enlace-permalink:hover {
                color: #ff1321;
                border-color: #ff1321;
            }

            @media (max-width: 720px) {
                .antologia-intro {
                    grid-template-columns: 1fr;
                }

                .antologia-figure {
                    border-right: 0;
                    border-bottom: 2px solid #111;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="antologia-intro">
                {antologia.data.heroImage && (
                    <figure class="antologia-figure">
                        <ContentImage src={antologia.data.heroImage} alt={antologia.data.title} width={480} priority />
                    </figure>
                )}
                <div class="antologia-sheet">
                    <p class="breadcrumb">
                        <a href="/poemas">Poemas</a> / Antología
                    </p>
                    <span class="antologia-badge">Antología</span>
                    <h1 class="antologia-titulo">{antologia.data.title}</h1>
                    <p class="antologia-descripcion">{antologia.data.description}</p>
                    <div class="antologia-meta">
                        {antologia.data.editor && (
                            <span>Curada por: {antologia.data.editor}</span>
                        )}
                        <span><FormattedDate date={antologia.data.pubDate} /></span>
                        <span>{poemas.length} poema{poemas.length !== 1 ? 's' : ''}</span>
                    </div>
                    <div class="antologia-body">
                        <Content />
                    </div>
                </div>
            </header>

            {poemasRenderizados.length > 0 && (
                <>
                    <p class="seccion-header">// Lectura continua</p>
                    <div class="antologia-lectura">
                        {poemasRenderizados.map(({ poema, Content: PoemaContent }) => (
                            <article class="poema-bloque" id={poema.id}>
                                <h2 class="poema-bloque-titulo">
                                    <a href={`/poemas/${poema.id}`}>{poema.data.title}</a>
                                </h2>
                                <div class="poema-bloque-meta">
                                    <span>{poema.data.author}</span>
                                    <span><FormattedDate date={poema.data.pubDate} /></span>
                                </div>
                                <div class="poema-bloque-cuerpo">
                                    <PoemaContent />
                                </div>
                                <a class="poema-enlace-permalink" href={`/poemas/${poema.id}`}>
                                    Enlace permanente →
                                </a>
                            </article>
                        ))}
                    </div>
                </>
            )}
        </main>
        <Footer />
    </body>
</html>
