---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ContentImage from '../../../components/ContentImage.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
    const antologias = await getCollection('antologias');
    return antologias.map((antologia) => ({
        params: { slug: antologia.id },
        props: { antologia },
    }));
}

const { antologia } = Astro.props;
const { Content } = await render(antologia);

const poemas = (await getCollection('poemas'))
    .filter((p) => p.data.antologia === antologia.id)
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const poemasRenderizados = await Promise.all(
    poemas.map(async (poema) => ({
        poema,
        ...(await render(poema)),
    }))
);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead
            title={`${antologia.data.title} | Antología | ${SITE_TITLE}`}
            description={antologia.data.description}
        />
        <style>
            main {
                width: min(960px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 4rem;
            }

            .breadcrumb {
                font-family: monospace;
                font-size: 0.75rem;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                margin-bottom: 1.5rem;
            }
            .breadcrumb a { color: #888; text-decoration: none; }
            .breadcrumb a:hover { color: #111; }

            .antologia-badge {
                display: inline-block;
                background: #111;
                color: #fff;
                font-family: monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                padding: 0.3rem 0.7rem;
                margin-bottom: 1rem;
            }

            .antologia-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.8rem, 4vw, 3rem);
                text-transform: uppercase;
                line-height: 1;
                margin: 0 0 1rem;
                color: #111;
            }

            .antologia-descripcion {
                font-family: 'Raleway', sans-serif;
                font-size: 1rem;
                line-height: 1.7;
                color: #444;
                margin-bottom: 1.5rem;
            }

            .antologia-meta {
                font-family: monospace;
                font-size: 0.75rem;
                color: #888;
                border-top: 1px solid #ddd;
                padding-top: 1rem;
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .antologia-intro {
                margin-bottom: 3rem;
            }

            .antologia-body {
                font-family: 'Raleway', sans-serif;
                font-size: 1rem;
                line-height: 1.7;
                color: #333;
                border-left: 4px solid #111;
                padding-left: 1.5rem;
                margin-top: 2rem;
            }
            .antologia-body p { margin-bottom: 1em; }

            .seccion-header {
                font-family: monospace;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: #888;
                border-bottom: 1px solid #ccc;
                padding-bottom: 0.6rem;
                margin-bottom: 2.5rem;
            }

            /* Lectura continua */
            .antologia-lectura {
                border: 3px solid #111;
                background: #fff;
            }

            .poema-bloque {
                padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3.5rem);
                border-bottom: 1px solid #ddd;
            }

            .poema-bloque:last-child {
                border-bottom: none;
            }

            .poema-bloque-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.3rem, 2.5vw, 1.9rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 0.6rem;
                color: #111;
            }

            .poema-bloque-titulo a {
                color: inherit;
                text-decoration: none;
            }

            .poema-bloque-titulo a:hover {
                color: #ff1321;
            }

            .poema-bloque-meta {
                font-family: monospace;
                font-size: 0.72rem;
                color: #888;
                margin-bottom: 1.5rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            .poema-bloque-cuerpo {
                font-family: 'Raleway', sans-serif;
                font-size: 1.05rem;
                line-height: 1.9;
                color: #222;
                white-space: pre-line;
            }

            .poema-bloque-cuerpo p {
                white-space: pre-line;
                margin-bottom: 1.5em;
            }

            .poema-enlace-permalink {
                display: inline-block;
                margin-top: 1.2rem;
                font-family: monospace;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #888;
                text-decoration: none;
                border-bottom: 1px solid #ccc;
            }

            .poema-enlace-permalink:hover {
                color: #ff1321;
                border-color: #ff1321;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <header class="antologia-intro editorial-split">
                {antologia.data.heroImage && (
                    <figure class="editorial-figure">
                        <ContentImage src={antologia.data.heroImage} alt={antologia.data.title} width={480} priority />
                    </figure>
                )}
                <div class="editorial-sheet">
                    <p class="breadcrumb">
                        <a href="/poemas">Poemas</a> / Antología
                    </p>
                    <span class="antologia-badge">Antología</span>
                    <h1 class="antologia-titulo">{antologia.data.title}</h1>
                    <p class="antologia-descripcion">{antologia.data.description}</p>
                    <div class="antologia-meta">
                        {antologia.data.editor && (
                            <span>Curada por: {antologia.data.editor}</span>
                        )}
                        <span><FormattedDate date={antologia.data.pubDate} /></span>
                        <span>{poemas.length} poema{poemas.length !== 1 ? 's' : ''}</span>
                    </div>
                    <div class="antologia-body">
                        <Content />
                    </div>
                </div>
            </header>

            {poemasRenderizados.length > 0 && (
                <>
                    <p class="seccion-header">// Lectura continua</p>
                    <div class="antologia-lectura">
                        {poemasRenderizados.map(({ poema, Content: PoemaContent }) => (
                            <article class="poema-bloque" id={poema.id}>
                                <h2 class="poema-bloque-titulo">
                                    <a href={`/poemas/${poema.id}`}>{poema.data.title}</a>
                                </h2>
                                <div class="poema-bloque-meta">
                                    <span>{poema.data.author}</span>
                                    <span><FormattedDate date={poema.data.pubDate} /></span>
                                </div>
                                <div class="poema-bloque-cuerpo">
                                    <PoemaContent />
                                </div>
                                <a class="poema-enlace-permalink" href={`/poemas/${poema.id}`}>
                                    Enlace permanente →
                                </a>
                            </article>
                        ))}
                    </div>
                </>
            )}
        </main>
        <Footer />
    </body>
</html>
