---
import { getCollection } from 'astro:content';
import SectionLayout from '../../layouts/SectionLayout.astro';
import ItemCard from '../../components/ui/ItemCard.astro';
import { SITE_TITLE } from '../../consts';

const antologias = (await getCollection('antologias')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const todosLosPoemas = (await getCollection('poemas')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const poemasEnAntologia = (slug: string) =>
    todosLosPoemas.filter((p) => p.data.antologia === slug);

const poemasLibres = todosLosPoemas.filter((p) => !p.data.antologia);
---

<SectionLayout 
    title={`Poemas | ${SITE_TITLE}`} 
    description="Archivo de poesía de Chelén"
    pageTitle="Poemas"
>
    {antologias.length > 0 && (
        <div class="antologias-section">
            <h2 class="seccion-header">// Antologías</h2>
            
            <ul class="antologias-list">
                {antologias.map((antologia) => {
                    const poemas = poemasEnAntologia(antologia.id);
                    return (
                        <li class="featured-item">
                            <ItemCard 
                                title={antologia.data.title}
                                href={`/poemas/antologia/${antologia.id}`}
                                heroImage={antologia.data.heroImage}
                                category={antologia.data.category || 'Antología'}
                                date={antologia.data.pubDate}
                                tags={antologia.data.tags}
                                format="portrait"
                                isFeatured={true}
                            >
                                <div class="antologia-extra">
                                    <p class="antologia-descripcion">{antologia.data.description}</p>
                                    
                                    {poemas.length > 0 && (
                                        <ul class="antologia-poemas-list">
                                            {poemas.map((poema) => (
                                                <li>{poema.data.title} — {poema.data.author}</li>
                                            ))}
                                        </ul>
                                    )}
                                    
                                    <div class="curador">
                                        {antologia.data.editor && (
                                            <span>Curada por: {antologia.data.editor}</span>
                                        )}
                                        <span>{poemas.length} poema{poemas.length !== 1 ? 's' : ''}</span>
                                    </div>
                                </div>
                            </ItemCard>
                        </li>
                    );
                })}
            </ul>
        </div>
    )}

    <h2 class="seccion-header">
        {antologias.length > 0 ? '// Poemas sueltos' : '// Poemas'}
    </h2>

    {poemasLibres.length === 0 ? (
        <div class="estado-vacio">
            <p>No hay poemas sueltos aún.</p>
        </div>
    ) : (
        <ul class="grid-list">
            {poemasLibres.map((poema) => (
                <li>
                    <ItemCard 
                        title={poema.data.title}
                        href={`/poemas/${poema.id}`}
                        heroImage={poema.data.heroImage}
                        category={poema.data.category || 'Poema'}
                        author={poema.data.author}
                        date={poema.data.pubDate}
                        tags={poema.data.tags}
                        format="portrait"
                    />
                </li>
            ))}
        </ul>
    )}
</SectionLayout>

<style>
    .seccion-header {
        font-family: 'Sifonn', sans-serif;
        font-size: clamp(1.2rem, 2.5vw, 1.75rem);
        text-transform: uppercase;
        line-height: 1;
        color: #111;
        border-top: 0.45rem solid #111;
        padding-top: 0.5rem;
        margin: 3rem 0 1.5rem;
    }
    
    .antologias-section .seccion-header {
        margin-top: 0;
    }

    .antologias-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    /* Transform ItemCard into a horizontal layout for featured Antologías */
    .antologias-list :global(.item-card.featured) {
        display: grid;
        grid-template-columns: minmax(280px, 0.72fr) 1fr;
        min-height: 0;
    }
    
    .antologias-list :global(.item-card.featured .item-media) {
        border-right: 2px solid #111;
        border-bottom: 0;
        height: 100%;
    }
    
    .antologias-list :global(.item-card.featured .item-body) {
        padding: clamp(1.25rem, 3vw, 2.5rem);
    }
    
    /* Extra content inside slot */
    .antologia-extra {
        margin-top: 1rem;
        border-top: 1px dashed #ddd;
        padding-top: 1rem;
    }

    .antologia-descripcion {
        font-family: 'Raleway', sans-serif;
        font-size: 1rem;
        line-height: 1.6;
        color: #444;
        margin: 0 0 1.25rem;
    }

    .antologia-poemas-list {
        margin: 0 0 1.5rem;
        list-style: none;
        padding: 0;
    }

    .antologia-poemas-list li {
        padding: 0.35rem 0;
        border-bottom: 1px dashed #ddd;
        font-family: 'Raleway', sans-serif;
        font-size: 0.9rem;
        line-height: 1.35;
    }

    .antologia-poemas-list li:last-child { 
        border-bottom: none; 
    }
    
    .curador {
        font-family: monospace;
        font-size: 0.75rem;
        color: #666;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    @media (max-width: 720px) {
        .antologias-list :global(.item-card.featured) { 
            grid-template-columns: 1fr; 
        }
        .antologias-list :global(.item-card.featured .item-media) { 
            border-right: 0; 
            border-bottom: 2px solid #111; 
        }
    }
</style>
