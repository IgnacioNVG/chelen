---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContentImage from '../../components/ContentImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const antologias = (await getCollection('antologias')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const todosLosPoemas = (await getCollection('poemas')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const poemasEnAntologia = (slug: string) =>
    todosLosPoemas.filter((p) => p.data.antologia === slug);

const poemasLibres = todosLosPoemas.filter((p) => !p.data.antologia);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Poemas | ${SITE_TITLE}`} description="Archivo de poesía de Chelén" />
        <style>
            main {
                width: min(960px, calc(100% - 2rem));
                margin: 0 auto;
                padding: 2.5rem 0 4rem;
            }

            .seccion-header {
                font-family: monospace;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: #888;
                border-bottom: 1px solid #ccc;
                padding-bottom: 0.6rem;
                margin-bottom: 2.5rem;
                margin-top: 3.5rem;
            }
            .seccion-header:first-child { margin-top: 0; }

            .antologia-badge {
                display: inline-block;
                background: #111;
                color: #fff;
                font-family: monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                padding: 0.3rem 0.6rem;
                margin-bottom: 1rem;
            }

            .antologia-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.6rem, 3vw, 2.4rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 1rem;
                color: #111;
            }

            .antologia-descripcion {
                font-family: 'Raleway', sans-serif;
                font-size: 1rem;
                line-height: 1.6;
                color: #444;
                margin-bottom: 1.5rem;
            }

            .antologia-meta {
                font-family: monospace;
                font-size: 0.75rem;
                color: #888;
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                border-top: 1px solid #ddd;
                padding-top: 1rem;
                margin-top: auto;
            }

            .antologia-poemas-list {
                margin: 0 0 1.5rem;
                list-style: none;
                padding: 0;
            }
            .antologia-poemas-list li {
                padding: 0.35rem 0;
                border-bottom: 1px dashed #ddd;
                font-family: 'Raleway', sans-serif;
                font-size: 0.9rem;
            }
            .antologia-poemas-list li:last-child { border-bottom: none; }

            .ver-antologia-link {
                display: inline-block;
                font-family: monospace;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #111;
                border-bottom: 2px solid #111;
                padding-bottom: 2px;
                text-decoration: none;
                transition: color 0.2s, border-color 0.2s;
            }
            .ver-antologia-link:hover {
                color: #FF1321;
                border-color: #FF1321;
            }

            .poema-titulo {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(1.3rem, 2.5vw, 2rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 1rem;
                color: #111;
            }

            .poema-meta {
                font-family: monospace;
                font-size: 0.75rem;
                color: #666;
                margin-top: auto;
                padding-top: 1rem;
                border-top: 1px solid #ddd;
                display: flex;
                flex-wrap: wrap;
                gap: 0.8rem;
            }

            .leer-link {
                display: inline-block;
                margin-top: 1rem;
                font-family: monospace;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #111;
                border-bottom: 2px solid #111;
                text-decoration: none;
                padding-bottom: 1px;
                transition: color 0.2s, border-color 0.2s;
                align-self: flex-start;
            }
            .leer-link:hover { color: #FF1321; border-color: #FF1321; }

            .estado-vacio {
                text-align: center;
                padding: 3rem 0;
                font-family: monospace;
                color: #aaa;
                font-size: 0.9rem;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            {antologias.length > 0 && (
                <>
                    <p class="seccion-header">// Antologías</p>

                    {antologias.map((antologia) => {
                        const poemas = poemasEnAntologia(antologia.id);
                        return (
                            <a
                                class="editorial-card-link"
                                href={`/poemas/antologia/${antologia.id}`}
                            >
                                {antologia.data.heroImage && (
                                    <figure class="editorial-figure">
                                        <ContentImage
                                            src={antologia.data.heroImage}
                                            alt={antologia.data.title}
                                            width={480}
                                        />
                                    </figure>
                                )}
                                <div class="editorial-sheet editorial-sheet--compact">
                                    <span class="antologia-badge">Antología</span>
                                    <h2 class="antologia-titulo">{antologia.data.title}</h2>
                                    <p class="antologia-descripcion">{antologia.data.description}</p>

                                    {poemas.length > 0 && (
                                        <ul class="antologia-poemas-list">
                                            {poemas.map((poema) => (
                                                <li>{poema.data.title} — {poema.data.author}</li>
                                            ))}
                                        </ul>
                                    )}

                                    <div class="antologia-meta">
                                        {antologia.data.editor && (
                                            <span>Curada por: {antologia.data.editor}</span>
                                        )}
                                        <span>
                                            <FormattedDate date={antologia.data.pubDate} />
                                        </span>
                                        <span>{poemas.length} poema{poemas.length !== 1 ? 's' : ''}</span>
                                    </div>

                                    <span class="ver-antologia-link">Leer antología →</span>
                                </div>
                            </a>
                        );
                    })}
                </>
            )}

            <p class="seccion-header">
                {antologias.length > 0 ? '// Poemas sueltos' : '// Poemas'}
            </p>

            {poemasLibres.length === 0 && (
                <p class="estado-vacio">No hay poemas sueltos aún.</p>
            )}

            {poemasLibres.map((poema) => (
                <a class="editorial-card-link" href={`/poemas/${poema.id}`}>
                    {poema.data.heroImage && (
                        <figure class="editorial-figure">
                            <ContentImage src={poema.data.heroImage} alt={poema.data.title} width={480} />
                        </figure>
                    )}
                    <div class="editorial-sheet editorial-sheet--compact">
                        <h2 class="poema-titulo">{poema.data.title}</h2>
                        <div class="poema-meta">
                            <span>{poema.data.author}</span>
                            <span><FormattedDate date={poema.data.pubDate} /></span>
                        </div>
                        <span class="leer-link">Leer poema →</span>
                    </div>
                </a>
            ))}
        </main>
        <Footer />
    </body>
</html>
