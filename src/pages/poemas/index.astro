---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const poemas = (await getCollection('poemas')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
    <head>
        <BaseHead title={`Poemas | ${SITE_TITLE}`} description="Espacio de debate y opinión" />
        <style>
            main { width: 960px; max-width: calc(100% - 3rem); margin: 0 auto; padding: 3rem 0; }
            .poemas-container { display: flex; gap: 4rem; align-items: flex-start; margin-top: 3rem; margin-bottom: 5rem; }
            .portada-wrapper { width: 40%; flex-shrink: 0; }
            .portada-wrapper img { width: 100%; aspect-ratio: 4/5; object-fit: cover; border: 6px solid #000; }
            .contenido-wrapper { width: 60%; }
            .titulo-Poemas { font-family: 'Sifonn', sans-serif; font-size: 2.5rem; text-transform: uppercase; margin-bottom: 1.5rem; }
            .meta-info { font-family: monospace; font-size: 0.9rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 2px solid #000; }
            @media (max-width: 720px) { .poemas-container { flex-direction: column; } .portada-wrapper, .contenido-wrapper { width: 100%; } }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h2 style="font-family: monospace;">// POEMAS</h2>
            
            {poemas.map((poemas) => (
                <section class="poemas-container">
                    <div class="portada-wrapper">
                        <a href={`/poemas/${poemas.id}`}>
                            <img src={poemas.data.heroImage || '/poemas-portada.webp'} alt={poemas.data.title} />
                        </a>
                    </div>
                    
                    <article class="contenido-wrapper">
                        <h1 class="titulo-poemas">
                            <a href={`/poemas/${poemas.id}`} style="text-decoration: none; color: inherit;">
                                {poemas.data.title}
                            </a>
                        </h1>
                        <div class="meta-info">
                            Por: {poemas.data.author} | <FormattedDate date={poemas.data.pubDate} />
                        </div>
                        <div class="cuerpo-poemas">
                            <p>{poemas.data.affiliation}</p>
                            <a href={`/poemas/${poemas.id}`}>Leer poema completo →</a>
                        </div>
                    </article>
                </section>
            ))}
        </main>
        <Footer />
    </body>
</html>