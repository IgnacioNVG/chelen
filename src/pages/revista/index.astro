---
import SectionLayout from '../../layouts/SectionLayout.astro';
import ItemCard from '../../components/ui/ItemCard.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { buildArticuloItems, buildCartaItems, mergeEditorialFeed } from '../../lib/homeFeed';

const articulos = await getCollection('articulos');
const cartas = await getCollection('cartas');
const feed = mergeEditorialFeed(buildArticuloItems(articulos), buildCartaItems(cartas));
---

<SectionLayout
    title={`Revista | ${SITE_TITLE}`}
    description="Producción escrita de Revista Chelén"
    pageTitle="Revista"
    introText=""
>
    <Fragment slot="hero">
        <header class="revista-hero brutalist-hero">
            <div class="hero-content">
                <span class="hero-kicker">Ecosistema de Ideas</span>
                <h1 class="hero-title">Revista<br><span class="hero-title-highlight">Chelén</span></h1>
                <p class="hero-intro">
                    Explora nuestra colección de ensayos, reseñas, columnas de opinión y cartas al director. Un ecosistema de ideas agrupado bajo una sola visión.
                </p>

                <div class="hero-nav">
                    <a href="/revista/articulos" class="nav-pill">
                        <span class="nav-text">Artículos</span>
                        <span class="nav-icon">→</span>
                    </a>
                    <a href="/revista/entrevistas" class="nav-pill">
                        <span class="nav-text">Entrevistas</span>
                        <span class="nav-icon">→</span>
                    </a>
                    <a href="/revista/columnas" class="nav-pill">
                        <span class="nav-text">Columnas</span>
                        <span class="nav-icon">→</span>
                    </a>
                    <a href="/revista/cartas" class="nav-pill">
                        <span class="nav-text">Cartas al Director</span>
                        <span class="nav-icon">→</span>
                    </a>
                </div>
            </div>

            <div class="hero-decoration">
                <div class="geo-shape geo-1"></div>
                <div class="geo-shape geo-2"></div>
                <div class="geo-shape geo-3"></div>
            </div>
        </header>
    </Fragment>

    <Fragment slot="band">
        <div class="section-band brutalist-band">
            <h2 class="band-title">Archivo <span>Completo</span></h2>
        </div>
    </Fragment>

    <ul class="revista-grid brutalist-masonry">
        {feed.map((item) => {
            const format = item.kind === 'carta' ? 'portrait' : 'landscape';

            return (
                <li class={`masonry-item format-${format}`}>
                    <ItemCard
                        title={item.title}
                        href={item.href}
                        heroImage={item.image}
                        category={item.category}
                        author={item.author}
                        date={item.pubDate}
                        tags={item.tags}
                        format={format}
                    />
                </li>
            );
        })}
    </ul>
</SectionLayout>

<style>
    /* ========================================================
       HERO SECTION - BRUTALISTA / CONSTRUCTIVISTA
       ======================================================== */
    .brutalist-hero {
        display: flex;
        flex-direction: column;
        border: 4px solid #111;
        background: #fff;
        box-shadow: 8px 8px 0px #111;
        margin-bottom: 4rem;
        position: relative;
        overflow: hidden;
    }

    @media (min-width: 992px) {
        .brutalist-hero {
            flex-direction: row;
            min-height: 450px;
        }
    }

    .hero-content {
        padding: clamp(2rem, 5vw, 4rem);
        flex: 1.2;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-right: 4px solid #111;
        background: #fff;
        z-index: 2;
    }

    .hero-kicker {
        display: inline-block;
        align-self: flex-start;
        font-family: monospace;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #fff;
        background-color: #111;
        padding: 0.35rem 0.85rem;
        margin-bottom: 1.5rem;
    }

    .hero-title {
        font-family: 'Sifonn', sans-serif;
        font-size: clamp(3rem, 8vw, 5.5rem);
        text-transform: uppercase;
        margin: 0 0 1.5rem 0;
        line-height: 0.9;
        color: #111;
    }

    .hero-title-highlight {
        color: #ff1321;
    }

    .hero-intro {
        font-size: 1.05rem;
        font-weight: 600;
        line-height: 1.6;
        color: #111;
        max-width: 550px;
        margin: 0 0 2.5rem 0;
        border-left: 5px solid #ff1321;
        padding-left: 1rem;
    }

    /* NAVEGACIÓN BRUTALISTA */
    .hero-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .nav-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: monospace;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #111;
        background-color: #fff;
        border: 2px solid #111;
        box-shadow: 4px 4px 0px #111;
        padding: 0.6rem 1.2rem;
        text-decoration: none;
        transition: all 0.15s ease-out;
    }

    .nav-pill:hover {
        transform: translate(-3px, -3px);
        box-shadow: 7px 7px 0px #ff1321;
        border-color: #ff1321;
        color: #ff1321;
    }

    /* DECORACIÓN GEOMÉTRICA */
    .hero-decoration {
        flex: 0.8;
        background: #f0f0f0;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .geo-shape {
        position: absolute;
        border: 4px solid #111;
    }

    .geo-1 {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: #ff1321;
        top: 15%;
        left: 20%;
        box-shadow: -8px 8px 0px #111;
    }

    .geo-2 {
        width: 250px;
        height: 80px;
        background: #111;
        bottom: 25%;
        right: -10%;
        transform: rotate(-15deg);
    }

    .geo-3 {
        width: 120px;
        height: 120px;
        background: #ffea00;
        top: -20px;
        right: 20%;
        transform: rotate(45deg);
        box-shadow: 6px 6px 0px #111;
    }

    @media (max-width: 991px) {
        .hero-decoration {
            display: none;
        }
        .hero-content {
            border-right: none;
        }
    }

    /* ========================================================
       SECTION BAND BRUTALISTA
       ======================================================== */
    .brutalist-band {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        border-top: 5px solid #111;
        padding-top: 1rem;
        margin: 3.5rem 0 2rem;
    }

    .band-title {
        font-family: 'Sifonn', sans-serif;
        font-size: clamp(1.5rem, 3.5vw, 2.5rem);
        text-transform: uppercase;
        margin: 0;
        color: #111;
    }

    .band-title span {
        color: #ff1321;
    }

    /* ========================================================
       GRID TIPO MASONRY (PINTEREST)
       ======================================================== */
    .brutalist-masonry {
        column-count: 1;
        column-gap: 2rem;
        list-style: none;
        padding: 0;
        margin: 0;
        width: 100%;
    }

    @media (min-width: 768px) {
        .brutalist-masonry {
            column-count: 2;
        }
    }

    @media (min-width: 1024px) {
        .brutalist-masonry {
            column-count: 3;
        }
    }

    /* Contenedor del item que evita romperse entre columnas */
    /* Contenedor del item */
    .masonry-item {
        break-inside: avoid;
        margin-bottom: 2rem;

        background: #fff;
        border: 2px solid #111;
        border-radius: 16px;      /* mismo radio que el grid */
        overflow: hidden;         /* imprescindible para que el radius recorte */

        box-shadow: 5px 5px 0 #111;
        transition:
            transform .15s ease-out,
            box-shadow .15s ease-out;

        display: flex;
        flex-direction: column;
    }

    .masonry-item:hover {
        transform: translate(-4px, -4px);
        box-shadow: 9px 9px 0 #ff1321;
    }

    /* El FeedCard interno ocupa todo el ancho */
    .masonry-item > * {
        width: 100%;
        margin: 0 !important;
    }

    /* Contenedor de imagen */
    .masonry-item :global([class*="feed-media"]) {
        overflow: hidden;
        border-bottom: 3px solid #111;
    }

    /* Imágenes */
    .masonry-item :global(img) {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .4s cubic-bezier(.25,.46,.45,.94), filter .4s;
        filter: grayscale(20%);
    }

    .masonry-item:hover :global(img) {
        transform: scale(1.08);
        filter: grayscale(0%);
    }

    /* Proporciones */
    .masonry-item.format-landscape :global(img) {
        aspect-ratio: 2 / 1;
    }

    .masonry-item.format-portrait :global(img) {
        aspect-ratio: 3 / 4;
    }
